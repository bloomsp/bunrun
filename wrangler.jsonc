{
	"compatibility_date": "2026-03-17",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "bunrun",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "bunrun",
			"database_id": "__SET_ME__"
		}
	],
	"observability": {
		"enabled": true
	}
}