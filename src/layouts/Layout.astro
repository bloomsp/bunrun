---
import '../styles/global.css';
import { getRoleFromRequest } from '../lib/auth';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const currentRole = Astro.isPrerendered ? null : getRoleFromRequest(Astro.request);
const pathname = Astro.url.pathname;
const isAdmin = currentRole === 'admin';
const isTeam = currentRole === 'team' || currentRole === 'admin';
const adminLinks = [
  { href: '/admin/schedule', label: 'Schedule' },
  { href: '/admin/members', label: 'Members' },
  { href: '/admin/areas', label: 'Areas' }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <meta name="theme-color" content="#00703c" />

    <meta name="robots" content="noindex" />
  </head>
  <body class="min-h-dvh bg-slate-50 text-slate-900">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-[96rem] items-center justify-between gap-4 px-3 py-4">
        <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
          <img src="/brand/bunnings-favicon.ico" width="18" height="18" alt="Bunnings" class="h-[18px] w-[18px]" />
          <span>Bunrun</span>
        </a>
        <div class="flex flex-wrap items-center justify-end gap-3 text-sm">
          <nav class="flex flex-wrap items-center gap-2">
            {isTeam && (
              <>
                <a class:list={['rounded-lg px-3 py-2 hover:bg-slate-100', pathname.startsWith('/reports') || pathname.startsWith('/view') ? 'bg-slate-100 text-slate-950' : 'text-slate-700 hover:text-slate-900']} href="/view">
                  Reports
                </a>
                <a class:list={['rounded-lg px-3 py-2 hover:bg-slate-100', pathname.startsWith('/breaks') ? 'bg-slate-100 text-slate-950' : 'text-slate-700 hover:text-slate-900']} href="/breaks">
                  Breaks
                </a>
              </>
            )}
            {isAdmin ? (
              adminLinks.map((link) => (
                <a
                  class:list={[
                    'rounded-lg px-3 py-2 hover:bg-slate-100',
                    pathname.startsWith(link.href) ? 'bg-emerald-50 text-emerald-950' : 'text-slate-700 hover:text-slate-900'
                  ]}
                  href={link.href}
                >
                  {link.label}
                </a>
              ))
            ) : (
              <a class:list={['rounded-lg px-3 py-2 hover:bg-slate-100', pathname.startsWith('/admin') ? 'bg-slate-100 text-slate-950' : 'text-slate-700 hover:text-slate-900']} href="/admin">
                Admin
              </a>
            )}
          </nav>
          {currentRole && (
            <form method="post" action="/api/logout">
              <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-700 hover:bg-slate-50 hover:text-slate-900" type="submit">
                Log out
              </button>
            </form>
          )}
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-12 border-t border-slate-200 bg-white">
      <div class="mx-auto max-w-[96rem] px-3 py-6 text-sm text-slate-600">
        Built for the Bunnings Cairns Central Service Desk team.
      </div>
    </footer>
  </body>
</html>
