---
import '../styles/global.css';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <meta name="theme-color" content="#00703c" />

    <meta name="robots" content="noindex" />
  </head>
  <body class="min-h-dvh bg-slate-50 text-slate-900">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
        <a href="/" class="font-semibold tracking-tight">Bunrun</a>
        <nav class="flex items-center gap-3 text-sm">
          <a class="text-slate-700 hover:text-slate-900" href="/view">View</a>
          <a class="text-slate-700 hover:text-slate-900" href="/admin">Admin</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-12 border-t border-slate-200 bg-white">
      <div class="mx-auto max-w-5xl px-4 py-6 text-sm text-slate-600">
        Built for the Bunnings Cairns Central Service Desk team.
      </div>
    </footer>
  </body>
</html>
