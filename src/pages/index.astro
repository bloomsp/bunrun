---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
---

<Layout title="Bunrun">
  <div class="mx-auto max-w-5xl px-4 py-10">
    <h1 class="text-3xl font-semibold tracking-tight">Bunrun</h1>
    <p class="mt-2 text-slate-700">
      Break coordination for the Service Desk team.
    </p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      <a
        class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:bg-slate-50"
        href="/view"
      >
        <div class="text-lg font-medium">Read-only view</div>
        <div class="mt-1 text-sm text-slate-600">Password required.</div>
      </a>

      <a
        class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:bg-slate-50"
        href="/admin"
      >
        <div class="text-lg font-medium">Admin</div>
        <div class="mt-1 text-sm text-slate-600">Coordinator login.</div>
      </a>
    </div>
  </div>
</Layout>
