---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import Runsheet from '../../../components/Runsheet.astro';
import { requireRole } from '../../../lib/auth';
import { getDB } from '../../../lib/db';
import { formatDurationMinutes } from '../../../lib/time';
import { REPORTS, loadViewSchedulePageData, type ReportKey, type BreakRow } from '../../../lib/view-data';

const guard = requireRole(Astro.request, 'view');
if (!guard.ok) return guard.redirect;

const date = Astro.params.date ?? '';
if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) {
  return new Response('Invalid date', { status: 400 });
}

const reportParam = (Astro.url.searchParams.get('report') || 'runsheet').toString() as ReportKey;
const selectedReport = REPORTS.some((report) => report.key === reportParam) ? reportParam : 'runsheet';
const reportLabel = REPORTS.find((report) => report.key === selectedReport)?.label ?? 'Runsheet';
const backHref = selectedReport === 'runsheet'
  ? `/view/${date}`
  : `/view/${date}?report=${selectedReport}`;

const DB = await getDB();
const {
  areas,
  areaByKey,
  shifts,
  breaks,
  groupedShifts,
  memberSortedShifts,
  chronologicalBreaks,
  memberSortedBreaks,
  groupedBreaks,
  areaCoveredByBreakId
} = await loadViewSchedulePageData(DB, date);

function coverLabel(row: BreakRow) {
  if (row.cover_member_name) return row.cover_member_name;
  return areaCoveredByBreakId.get(row.id) ? 'Area covered' : 'Missing cover';
}

---

<Layout title={`Print ${reportLabel} ${date} | Bunrun`}>
  <style>
    @media print {
      header, footer { display: none !important; }
      main { padding: 0 !important; }
    }
  </style>

  <div class="px-4 py-6">
    <div class="mb-4 flex items-center justify-between gap-3">
      <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href={backHref}>
        Back
      </a>
      <div class="text-sm text-slate-600">{reportLabel}</div>
    </div>

    {selectedReport === 'runsheet' && (
      <Runsheet
        date={date}
        areas={areas}
        shifts={shifts}
        breaks={breaks.map((row) => ({
          ...row,
          area_covered: areaCoveredByBreakId.get(row.id) === true
        }))}
        variant="print"
      />
    )}

    {selectedReport === 'shifts-by-area' && (
      <div class="space-y-6">
        {groupedShifts.map(({ area, rows }) => (
          <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">{area.label}</h2>
            <table class="mt-4 w-full text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-left text-slate-600">
                  <th class="px-3 py-2">Member</th>
                  <th class="px-3 py-2">Start</th>
                  <th class="px-3 py-2">End</th>
                  <th class="px-3 py-2">Length</th>
                  <th class="px-3 py-2">Role</th>
                  <th class="px-3 py-2">Status</th>
                </tr>
              </thead>
              <tbody>
                {rows.map((shift) => (
                  <tr class="border-b border-slate-100 last:border-b-0">
                    <td class="px-3 py-2">{shift.name}</td>
                    <td class="px-3 py-2">{shift.start_time}</td>
                    <td class="px-3 py-2">{shift.end_time ?? '—'}</td>
                    <td class="px-3 py-2">{formatDurationMinutes(Number(shift.shift_minutes ?? 0))}</td>
                    <td class="px-3 py-2">{shift.shift_role === 'floater' ? 'Floater' : 'Normal'}</td>
                    <td class="px-3 py-2">{shift.status_key}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </section>
        ))}
      </div>
    )}

    {selectedReport === 'shifts-by-member' && (
      <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 text-left text-slate-600">
              <th class="px-3 py-2">Member</th>
              <th class="px-3 py-2">Area</th>
              <th class="px-3 py-2">Start</th>
              <th class="px-3 py-2">End</th>
              <th class="px-3 py-2">Length</th>
              <th class="px-3 py-2">Role</th>
              <th class="px-3 py-2">Status</th>
            </tr>
          </thead>
          <tbody>
            {memberSortedShifts.map((shift) => (
              <tr class="border-b border-slate-100 last:border-b-0">
                <td class="px-3 py-2">{shift.name}</td>
                <td class="px-3 py-2">{areaByKey.get(shift.home_area_key) ?? shift.home_area_key}</td>
                <td class="px-3 py-2">{shift.start_time}</td>
                <td class="px-3 py-2">{shift.end_time ?? '—'}</td>
                <td class="px-3 py-2">{formatDurationMinutes(Number(shift.shift_minutes ?? 0))}</td>
                <td class="px-3 py-2">{shift.shift_role === 'floater' ? 'Floater' : 'Normal'}</td>
                <td class="px-3 py-2">{shift.status_key}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    {selectedReport === 'breaks-chronological' && (
      <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 text-left text-slate-600">
              <th class="px-3 py-2">Time</th>
              <th class="px-3 py-2">Member</th>
              <th class="px-3 py-2">Area</th>
              <th class="px-3 py-2">Duration</th>
              <th class="px-3 py-2">Cover</th>
            </tr>
          </thead>
          <tbody>
            {chronologicalBreaks.map((row) => (
              <tr class="border-b border-slate-100 last:border-b-0">
                <td class="px-3 py-2">{row.start_time}</td>
                <td class="px-3 py-2">{row.off_member_name}</td>
                <td class="px-3 py-2">{areaByKey.get(row.off_area_key) ?? row.off_area_key}</td>
                <td class="px-3 py-2">{row.duration_minutes}m</td>
                <td class="px-3 py-2">{coverLabel(row)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    {selectedReport === 'breaks-by-area' && (
      <div class="space-y-6">
        {groupedBreaks.map(({ area, rows }) => (
          <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">{area.label}</h2>
            <table class="mt-4 w-full text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-left text-slate-600">
                  <th class="px-3 py-2">Time</th>
                  <th class="px-3 py-2">Member</th>
                  <th class="px-3 py-2">Duration</th>
                  <th class="px-3 py-2">Cover</th>
                </tr>
              </thead>
              <tbody>
                {rows.map((row) => (
                  <tr class="border-b border-slate-100 last:border-b-0">
                    <td class="px-3 py-2">{row.start_time}</td>
                    <td class="px-3 py-2">{row.off_member_name}</td>
                    <td class="px-3 py-2">{row.duration_minutes}m</td>
                    <td class="px-3 py-2">{coverLabel(row)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </section>
        ))}
      </div>
    )}

    {selectedReport === 'breaks-by-member' && (
      <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 text-left text-slate-600">
              <th class="px-3 py-2">Member</th>
              <th class="px-3 py-2">Time</th>
              <th class="px-3 py-2">Area</th>
              <th class="px-3 py-2">Duration</th>
              <th class="px-3 py-2">Cover</th>
            </tr>
          </thead>
          <tbody>
            {memberSortedBreaks.map((row) => (
              <tr class="border-b border-slate-100 last:border-b-0">
                <td class="px-3 py-2">{row.off_member_name}</td>
                <td class="px-3 py-2">{row.start_time}</td>
                <td class="px-3 py-2">{areaByKey.get(row.off_area_key) ?? row.off_area_key}</td>
                <td class="px-3 py-2">{row.duration_minutes}m</td>
                <td class="px-3 py-2">{coverLabel(row)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    <div class="mt-4 text-sm text-slate-600">
      Print this page to PDF.
    </div>
  </div>
</Layout>
