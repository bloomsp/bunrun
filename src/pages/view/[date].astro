---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import ErrorState from '../../components/ErrorState.astro';
import Runsheet from '../../components/Runsheet.astro';
import { requireRole } from '../../lib/auth';
import { getDB } from '../../lib/db';
import { friendlyDbError } from '../../lib/errors';
import { formatDurationMinutes } from '../../lib/time';
import { formatLongDateLabel, formatShortDateLabel } from '../../lib/schedule';
import { REPORTS, loadViewSchedulePageData, type ReportKey, type BreakRow, type BreakTakenRow, type BreakTakenSummary } from '../../lib/view-data';

const guard = requireRole(Astro.request, 'view');
if (!guard.ok) return guard.redirect;

const date = Astro.params.date ?? '';
if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) {
  return new Response('Invalid date', { status: 400 });
}

const reportParam = (Astro.url.searchParams.get('report') || 'runsheet').toString() as ReportKey;
const selectedReport = REPORTS.some((report) => report.key === reportParam) ? reportParam : 'runsheet';
const reportLabel = REPORTS.find((report) => report.key === selectedReport)?.label ?? 'Runsheet';
const reportHref = (targetDate: string, report: ReportKey) => report === 'runsheet'
  ? `/view/${targetDate}`
  : `/view/${targetDate}?report=${report}`;
const printHref = selectedReport === 'runsheet'
  ? `/view/${date}/print`
  : `/view/${date}/print?report=${selectedReport}`;

let pageError: ReturnType<typeof friendlyDbError> | null = null;
let weekStart = date;
let weekDates: string[] = [];
let previousWeekDate = date;
let nextWeekDate = date;
let weekCountsByDate = new Map<string, number>();
let areas: any[] = [];
let areaByKey = new Map<string, string>();
let shifts: any[] = [];
let breaks: BreakRow[] = [];
let groupedShifts: any[] = [];
let memberSortedShifts: any[] = [];
let chronologicalBreaks: BreakRow[] = [];
let memberSortedBreaks: BreakRow[] = [];
let breaksTakenRows: BreakTakenRow[] = [];
let breakTakenSummary: BreakTakenSummary = {
  totalBreaks: 0,
  recordedBreaks: 0,
  missingBreaks: 0,
  onTimeBreaks: 0,
  earlyBreaks: 0,
  lateBreaks: 0,
  averageVarianceAbsMinutes: null
};
let groupedBreaks: any[] = [];
let areaCoveredByBreakId = new Map<number, boolean>();

try {
  const DB = await getDB();
  ({
  weekStart,
  weekDates,
  previousWeekDate,
  nextWeekDate,
  weekCountsByDate,
  areas,
  areaByKey,
  shifts,
  breaks,
  groupedShifts,
  memberSortedShifts,
  chronologicalBreaks,
  memberSortedBreaks,
  breaksTakenRows,
  breakTakenSummary,
  groupedBreaks,
  areaCoveredByBreakId
  } = await loadViewSchedulePageData(DB, date));
} catch (error) {
  pageError = friendlyDbError(error);
}

function coverLabel(row: BreakRow) {
  if (row.cover_member_name) return row.cover_member_name;
  return areaCoveredByBreakId.get(row.id) ? 'Area covered' : 'Missing cover';
}
---

<Layout title={`${reportLabel} ${date} | Bunrun`}>
  {pageError ? (
    <div class="px-3 py-10">
      <ErrorState title={pageError.title} message={pageError.message} details={pageError.details} />
    </div>
  ) : (
  <div class="mx-auto max-w-[96rem] px-3 py-10">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight">Read-only schedule</h1>
        <div class="mt-1 text-slate-700">{formatLongDateLabel(date)}</div>
        <div class="mt-1 text-sm text-slate-500">Week of {weekStart}</div>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href="/view">Change date</a>
        <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href={reportHref(previousWeekDate, selectedReport)}>
          Previous week
        </a>
        <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href={reportHref(nextWeekDate, selectedReport)}>
          Next week
        </a>
      </div>
    </div>

    <div class="mt-6 overflow-x-auto">
      <div class="flex min-w-max gap-3">
        {weekDates.map((tabDate) => {
          const shiftCount = weekCountsByDate.get(tabDate) ?? 0;
          const active = tabDate === date;
          return (
            <a
              class:list={[
                'min-w-[132px] rounded-2xl border px-4 py-3 text-left transition',
                active
                  ? 'border-emerald-600 bg-emerald-50 text-emerald-950 shadow-sm'
                  : 'border-slate-200 bg-white text-slate-800 hover:border-slate-300 hover:bg-slate-50'
              ]}
              href={reportHref(tabDate, selectedReport)}
            >
              <div class="text-sm font-semibold">{formatShortDateLabel(tabDate)}</div>
              <div class="mt-1 text-xs text-slate-600">
                {shiftCount} shift{shiftCount === 1 ? '' : 's'}
              </div>
            </a>
          );
        })}
      </div>
    </div>

    <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
      <div class="flex flex-wrap gap-2">
        {REPORTS.map((report) => (
          <a
            class:list={[
              'rounded-full border px-3 py-1.5 text-sm transition',
              report.key === selectedReport
                ? 'border-emerald-600 bg-emerald-50 text-emerald-950'
                : 'border-slate-300 bg-white text-slate-700 hover:bg-slate-50'
            ]}
            href={reportHref(date, report.key)}
          >
            {report.label}
          </a>
        ))}
      </div>
      <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href={printHref}>
        Print / PDF
      </a>
    </div>

    {selectedReport === 'runsheet' && (
      <Runsheet
        date={date}
        areas={areas}
        shifts={shifts}
        breaks={breaks.map((row) => ({
          ...row,
          area_covered: areaCoveredByBreakId.get(row.id) === true
        }))}
      />
    )}

    {selectedReport === 'shifts-by-area' && (
      <div class="mt-6 space-y-6">
        {groupedShifts.map(({ area, rows }) => (
          <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">{area.label}</h2>
            <div class="mt-4 overflow-x-auto">
              <table class="w-full min-w-[720px] text-sm">
                <thead>
                  <tr class="border-b border-slate-200 text-left text-slate-600">
                    <th class="px-3 py-2">Member</th>
                    <th class="px-3 py-2">Start</th>
                    <th class="px-3 py-2">End</th>
                    <th class="px-3 py-2">Length</th>
                    <th class="px-3 py-2">Role</th>
                    <th class="px-3 py-2">Status</th>
                  </tr>
                </thead>
                <tbody>
                  {rows.map((shift) => (
                    <tr class="border-b border-slate-100 last:border-b-0">
                      <td class="px-3 py-2">{shift.name}</td>
                      <td class="px-3 py-2">{shift.start_time}</td>
                      <td class="px-3 py-2">{shift.end_time ?? '—'}</td>
                      <td class="px-3 py-2">{formatDurationMinutes(Number(shift.shift_minutes ?? 0))}</td>
                      <td class="px-3 py-2">{shift.shift_role === 'floater' ? 'Floater' : 'Normal'}</td>
                      <td class="px-3 py-2">{shift.status_key}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        ))}
      </div>
    )}

    {selectedReport === 'shifts-by-member' && (
      <div class="mt-6 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="overflow-x-auto">
          <table class="w-full min-w-[760px] text-sm">
            <thead>
              <tr class="border-b border-slate-200 text-left text-slate-600">
                <th class="px-3 py-2">Member</th>
                <th class="px-3 py-2">Area</th>
                <th class="px-3 py-2">Start</th>
                <th class="px-3 py-2">End</th>
                <th class="px-3 py-2">Length</th>
                <th class="px-3 py-2">Role</th>
                <th class="px-3 py-2">Status</th>
              </tr>
            </thead>
            <tbody>
              {memberSortedShifts.map((shift) => (
                <tr class="border-b border-slate-100 last:border-b-0">
                  <td class="px-3 py-2">{shift.name}</td>
                  <td class="px-3 py-2">{areaByKey.get(shift.home_area_key) ?? shift.home_area_key}</td>
                  <td class="px-3 py-2">{shift.start_time}</td>
                  <td class="px-3 py-2">{shift.end_time ?? '—'}</td>
                  <td class="px-3 py-2">{formatDurationMinutes(Number(shift.shift_minutes ?? 0))}</td>
                  <td class="px-3 py-2">{shift.shift_role === 'floater' ? 'Floater' : 'Normal'}</td>
                  <td class="px-3 py-2">{shift.status_key}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

    {selectedReport === 'breaks-chronological' && (
      <div class="mt-6 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="overflow-x-auto">
          <table class="w-full min-w-[760px] text-sm">
            <thead>
              <tr class="border-b border-slate-200 text-left text-slate-600">
                <th class="px-3 py-2">Time</th>
                <th class="px-3 py-2">Member</th>
                <th class="px-3 py-2">Area</th>
                <th class="px-3 py-2">Duration</th>
                <th class="px-3 py-2">Cover</th>
              </tr>
            </thead>
            <tbody>
              {chronologicalBreaks.map((row) => (
                <tr class="border-b border-slate-100 last:border-b-0">
                  <td class="px-3 py-2">{row.start_time}</td>
                  <td class="px-3 py-2">{row.off_member_name}</td>
                  <td class="px-3 py-2">{areaByKey.get(row.off_area_key) ?? row.off_area_key}</td>
                  <td class="px-3 py-2">{row.duration_minutes}m</td>
                  <td class="px-3 py-2">{coverLabel(row)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

    {selectedReport === 'breaks-by-area' && (
      <div class="mt-6 space-y-6">
        {groupedBreaks.map(({ area, rows }) => (
          <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">{area.label}</h2>
            <div class="mt-4 overflow-x-auto">
              <table class="w-full min-w-[760px] text-sm">
                <thead>
                  <tr class="border-b border-slate-200 text-left text-slate-600">
                    <th class="px-3 py-2">Time</th>
                    <th class="px-3 py-2">Member</th>
                    <th class="px-3 py-2">Duration</th>
                    <th class="px-3 py-2">Cover</th>
                  </tr>
                </thead>
                <tbody>
                  {rows.map((row) => (
                    <tr class="border-b border-slate-100 last:border-b-0">
                      <td class="px-3 py-2">{row.start_time}</td>
                      <td class="px-3 py-2">{row.off_member_name}</td>
                      <td class="px-3 py-2">{row.duration_minutes}m</td>
                      <td class="px-3 py-2">{coverLabel(row)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        ))}
      </div>
    )}

    {selectedReport === 'breaks-by-member' && (
      <div class="mt-6 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="overflow-x-auto">
          <table class="w-full min-w-[760px] text-sm">
            <thead>
              <tr class="border-b border-slate-200 text-left text-slate-600">
                <th class="px-3 py-2">Member</th>
                <th class="px-3 py-2">Time</th>
                <th class="px-3 py-2">Area</th>
                <th class="px-3 py-2">Duration</th>
                <th class="px-3 py-2">Cover</th>
              </tr>
            </thead>
            <tbody>
              {memberSortedBreaks.map((row) => (
                <tr class="border-b border-slate-100 last:border-b-0">
                  <td class="px-3 py-2">{row.off_member_name}</td>
                  <td class="px-3 py-2">{row.start_time}</td>
                  <td class="px-3 py-2">{areaByKey.get(row.off_area_key) ?? row.off_area_key}</td>
                  <td class="px-3 py-2">{row.duration_minutes}m</td>
                  <td class="px-3 py-2">{coverLabel(row)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

    {selectedReport === 'breaks-taken' && (
      <div class="mt-6 space-y-6">
        <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-5">
          <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">Breaks planned</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900">{breakTakenSummary.totalBreaks}</div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">Actual times recorded</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900">{breakTakenSummary.recordedBreaks}</div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">Missing actual times</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900">{breakTakenSummary.missingBreaks}</div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">On time</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900">{breakTakenSummary.onTimeBreaks}</div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">Average variance</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900">{breakTakenSummary.averageVarianceAbsMinutes != null ? `${breakTakenSummary.averageVarianceAbsMinutes}m` : '—'}</div>
          </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <div class="flex flex-wrap items-center gap-4 text-sm text-slate-600">
            <div><span class="font-medium text-slate-900">Early:</span> {breakTakenSummary.earlyBreaks}</div>
            <div><span class="font-medium text-slate-900">Late:</span> {breakTakenSummary.lateBreaks}</div>
            <div><span class="font-medium text-slate-900">Use:</span> compare scheduled vs actual break timing for operational drift.</div>
          </div>

          <div class="mt-4 overflow-x-auto">
            <table class="w-full min-w-[980px] text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-left text-slate-600">
                  <th class="px-3 py-2">Member</th>
                  <th class="px-3 py-2">Area</th>
                  <th class="px-3 py-2">Scheduled</th>
                  <th class="px-3 py-2">Actual</th>
                  <th class="px-3 py-2">Variance</th>
                  <th class="px-3 py-2">Duration</th>
                  <th class="px-3 py-2">Cover</th>
                </tr>
              </thead>
              <tbody>
                {breaksTakenRows.map((row) => (
                  <tr class="border-b border-slate-100 last:border-b-0">
                    <td class="px-3 py-2">{row.off_member_name}</td>
                    <td class="px-3 py-2">{areaByKey.get(row.off_area_key) ?? row.off_area_key}</td>
                    <td class="px-3 py-2">{row.start_time}</td>
                    <td class="px-3 py-2">{row.actual_start_time ?? '—'}</td>
                    <td class:list={[
                      'px-3 py-2 font-medium',
                      row.variance_minutes == null ? 'text-slate-500' : row.variance_minutes === 0 ? 'text-emerald-700' : row.variance_minutes > 0 ? 'text-amber-700' : 'text-sky-700'
                    ]}>{row.timing_label}</td>
                    <td class="px-3 py-2">{row.duration_minutes}m</td>
                    <td class="px-3 py-2">{coverLabel(row)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    )}
  </div>
  )}
</Layout>
