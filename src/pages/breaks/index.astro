---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { requireRole } from '../../lib/auth';

const guard = requireRole(Astro.request, 'team');
if (!guard.ok) return guard.redirect;

const picked = Astro.url.searchParams.get('date');
if (picked && /^\d{4}-\d{2}-\d{2}$/.test(picked)) {
  return new Response(null, { status: 303, headers: { Location: `/breaks/${picked}` } });
}

const today = new Date();
const yyyy = today.getFullYear();
const mm = String(today.getMonth() + 1).padStart(2, '0');
const dd = String(today.getDate()).padStart(2, '0');
const defaultDate = `${yyyy}-${mm}-${dd}`;
---

<Layout title="Breaks | Bunrun">
  <div class="mx-auto max-w-3xl px-4 py-10">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-semibold tracking-tight">Record breaks</h1>
    </div>

    <p class="mt-2 text-slate-700">Open a date to record when breaks were actually taken.</p>

    <form class="mt-6 flex flex-wrap items-end gap-3" method="get" action="/breaks">
      <label class="block">
        <div class="text-sm font-medium text-slate-800">Date</div>
        <input class="mt-1 rounded-lg border border-slate-300 bg-white px-3 py-2" type="date" name="date" value={defaultDate} required />
      </label>

      <button class="rounded-lg bg-slate-900 px-4 py-2.5 font-medium text-white hover:bg-slate-800" type="submit">
        Open
      </button>
    </form>

    <div class="mt-6">
      <a class="underline" href={`/breaks/${defaultDate}`}>Go to today</a>
    </div>
  </div>
</Layout>
