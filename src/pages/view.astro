---
import Layout from '../layouts/Layout.astro';
import { requireRole } from '../lib/auth';

const guard = requireRole(Astro.request, 'view');
if (!guard.ok) {
  return guard.redirect;
}
---

<Layout title="View | Bunrun">
  <div class="mx-auto max-w-5xl px-4 py-10">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-semibold tracking-tight">Roster (read-only)</h1>
      <form method="post" action="/api/logout">
        <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" type="submit">
          Log out
        </button>
      </form>
    </div>

    <p class="mt-2 text-slate-700">
      MVP placeholder. Next: schedule table + break timeline + PDF export.
    </p>
  </div>
</Layout>
