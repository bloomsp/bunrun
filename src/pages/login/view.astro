---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="View login | Bunrun">
  <div class="mx-auto max-w-md px-4 py-10">
    <h1 class="text-2xl font-semibold tracking-tight">View login</h1>
    <p class="mt-2 text-slate-700">Enter the view password to continue.</p>

    <form class="mt-6 space-y-4" method="post" action="/api/login">
      <input type="hidden" name="role" value="view" />

      <label class="block">
        <div class="text-sm font-medium text-slate-800">Password</div>
        <input class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" type="password" name="password" required autocomplete="current-password" />
      </label>

      <button class="w-full rounded-lg bg-slate-900 px-4 py-2.5 font-medium text-white hover:bg-slate-800" type="submit">
        Sign in
      </button>

      <div class="text-sm text-slate-600">
        <a class="underline" href="/login/admin">Switch to admin login</a>
      </div>
    </form>
  </div>
</Layout>
