---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Login | Bunrun">
  <div class="mx-auto max-w-md px-4 py-10">
    <h1 class="text-2xl font-semibold tracking-tight">Login</h1>
    <p class="mt-2 text-slate-700">Choose a login type.</p>

    <div class="mt-6 grid gap-3">
      <a class="rounded-lg bg-slate-900 px-4 py-3 text-center font-medium text-white hover:bg-slate-800" href="/login/team">
        Team Member
      </a>
      <a class="rounded-lg bg-emerald-700 px-4 py-3 text-center font-medium text-white hover:bg-emerald-800" href="/login/admin">
        Admin
      </a>
    </div>
  </div>
</Layout>
