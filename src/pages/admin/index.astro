---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { requireRole } from '../../lib/auth';

const guard = requireRole(Astro.request, 'admin');
if (!guard.ok) {
  return guard.redirect;
}
---

<Layout title="Admin | Bunrun">
  <div class="mx-auto max-w-[96rem] px-3 py-10">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-semibold tracking-tight">Admin (coordinator)</h1>
    </div>

    <p class="mt-2 text-slate-700">
      Manage daily rosters, members, areas, break generation, and cover assignments for the Service Desk team.
    </p>

    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      <a class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:bg-slate-50" href="/admin/schedule">
        <div class="text-lg font-medium">Schedule</div>
        <div class="mt-1 text-sm text-slate-600">Create the roster for a day and add shifts.</div>
      </a>

      <a class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:bg-slate-50" href="/admin/members">
        <div class="text-lg font-medium">Members</div>
        <div class="mt-1 text-sm text-slate-600">Add/deactivate people, restrict allowed areas, and set break preferences.</div>
      </a>

      <a class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:bg-slate-50" href="/admin/areas">
        <div class="text-lg font-medium">Areas</div>
        <div class="mt-1 text-sm text-slate-600">Rename areas and configure minimum staffing.</div>
      </a>
    </div>

    <div class="mt-6 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-medium">What you can do here</h2>
      <ul class="mt-2 list-disc pl-5 text-sm text-slate-700">
        <li>Build or copy daily and weekly rosters</li>
        <li>Assign members to areas, roles, and statuses</li>
        <li>Auto-generate breaks for continuous work blocks</li>
        <li>Review missing or invalid cover assignments</li>
        <li>Maintain area minimum staffing and member permissions</li>
      </ul>
    </div>
  </div>
</Layout>
