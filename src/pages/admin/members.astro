---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { requireRole } from '../../lib/auth';
import { getDB } from '../../lib/db';

const guard = requireRole(Astro.request, 'admin');
if (!guard.ok) return guard.redirect;

type Member = { id: number; name: string; active: number; all_areas: number; default_area_key: string | null };

type Area = { key: string; label: string };

type Permission = { member_id: number; area_key: string };

const editId = Number(Astro.url.searchParams.get('edit') || '0');

let members: Member[] = [];
let areas: Area[] = [];
let perms: Permission[] = [];
let dbError: string | null = null;

try {
  const DB = await getDB();
  members = (await DB.prepare('SELECT id, name, active, all_areas, default_area_key FROM members ORDER BY name COLLATE NOCASE ASC').all())
    .results as Member[];
  areas = (await DB.prepare('SELECT key, label FROM areas ORDER BY label COLLATE NOCASE ASC').all()).results as Area[];
  perms = (await DB.prepare('SELECT member_id, area_key FROM member_area_permissions').all()).results as Permission[];
} catch (e: any) {
  dbError = e?.message ?? String(e);
}

function allowedAreasFor(memberId: number) {
  return new Set(perms.filter((p) => p.member_id === memberId).map((p) => p.area_key));
}
---

<Layout title="Members | Bunrun">
  <div class="mx-auto max-w-5xl px-4 py-10">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-semibold tracking-tight">Members</h1>
      <a class="text-sm underline" href="/admin">Back</a>
    </div>

    <p class="mt-2 text-slate-700">
      Add/deactivate members and manage which areas each person can work (applies to home area and break coverage).
    </p>

    <div class="mt-6 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-medium">Add member</h2>
      <form class="mt-3 flex gap-2" method="post" action="/api/members/add">
        <input class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="name" placeholder="Name" required />
        <button class="rounded-lg bg-emerald-700 px-4 py-2 font-medium text-white hover:bg-emerald-800" type="submit">
          Add
        </button>
      </form>
    </div>

    {dbError ? (
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-5 text-amber-900">
        <div class="font-medium">DB not configured yet</div>
        <div class="mt-2 text-sm">{dbError}</div>
        <div class="mt-3 text-sm">
          Once the Cloudflare D1 binding <code class="rounded bg-white px-1">DB</code> is configured and migrations are applied,
          this page will populate.
        </div>
      </div>
    ) : (
      <div class="mt-6 space-y-4">
        {members.map((m) => {
          const allowed = allowedAreasFor(m.id);
          const isEditing = editId === m.id;

          return (
            <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                  <div class="text-lg font-semibold">{m.name}</div>
                  <div class="mt-1 text-sm text-slate-600">
                    Status: {m.active ? 'Active' : 'Inactive'}
                    {' · '}
                    Areas: {m.all_areas ? 'All areas' : 'Restricted'}
                  </div>

                  {!m.all_areas && (
                    <div class="mt-1 text-sm text-slate-600">
                      Allowed: {Array.from(allowed)
                        .map((k) => areas.find((a) => a.key === k)?.label ?? k)
                        .sort((a, b) => a.localeCompare(b))
                        .join(', ') || '—'}
                    </div>
                  )}
                </div>

                <div class="flex flex-wrap items-center gap-2">
                  <form method="post" action="/api/members/toggle-active">
                    <input type="hidden" name="memberId" value={m.id} />
                    <input type="hidden" name="active" value={m.active ? '0' : '1'} />
                    <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" type="submit">
                      {m.active ? 'Deactivate' : 'Reactivate'}
                    </button>
                  </form>

                  <form method="post" action="/api/members/set-all-areas">
                    <input type="hidden" name="memberId" value={m.id} />
                    <input type="hidden" name="allAreas" value="1" />
                    <button
                      class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50"
                      type="submit"
                      disabled={!m.active}
                    >
                      Allow all areas
                    </button>
                  </form>

                  <a
                    class="rounded-lg bg-emerald-700 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-800"
                    href={`/admin/members?edit=${m.id}#member-${m.id}`}
                  >
                    Modify
                  </a>
                </div>
              </div>

              {isEditing && (
                <form class="mt-4" method="post" action="/api/members/update">
                  <input type="hidden" name="memberId" value={m.id} />
                  <input type="hidden" name="returnTo" value="/admin/members" />

                  <div class="grid gap-4 sm:grid-cols-3">
                    <label class="block sm:col-span-1">
                      <div class="text-sm font-medium text-slate-800">Name</div>
                      <input
                        class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
                        name="name"
                        value={m.name}
                        required
                      />
                    </label>

                    <label class="block sm:col-span-1">
                      <div class="text-sm font-medium text-slate-800">Default area</div>
                      <select
                        class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
                        name="defaultAreaKey"
                      >
                        <option value="" selected={!m.default_area_key}>—</option>
                        {areas.map((a) => (
                          <option value={a.key} selected={m.default_area_key === a.key}>{a.label}</option>
                        ))}
                      </select>
                    </label>

                    <div class="sm:col-span-1">
                      <div class="text-sm font-medium text-slate-800">Allowed areas</div>
                      <div class="mt-1 text-sm text-slate-600">Applies to home area and break coverage.</div>
                    </div>
                  </div>

                  <div class="mt-2 grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
                    {areas.map((a) => (
                      <label class="flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm">
                        <input
                          type="checkbox"
                          name="areas"
                          value={a.key}
                          checked={m.all_areas ? true : allowed.has(a.key)}
                        />
                        <span>{a.label}</span>
                      </label>
                    ))}
                  </div>

                  <div class="mt-3 flex flex-wrap items-center gap-2">
                    <button
                      class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800"
                      type="submit"
                      disabled={!m.active}
                    >
                      Save
                    </button>
                    <a
                      class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm hover:bg-slate-50"
                      href="/admin/members"
                    >
                      Cancel
                    </a>
                    <div class="text-sm text-slate-600">Changes apply to home area and break coverage.</div>
                  </div>
                </form>
              )}
            </section>
          );
        })}
      </div>
    )}
  </div>
</Layout>
ayout>
