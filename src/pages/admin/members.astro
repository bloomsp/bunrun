---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { requireRole } from '../../lib/auth';
import { getDB } from '../../lib/db';
import { BREAK_PREFERENCES } from '../../lib/member-config';
import { loadAreas, loadMembers, loadPermissions } from '../../lib/lookups';

const guard = requireRole(Astro.request, 'admin');
if (!guard.ok) return guard.redirect;

type Member = {
  id: number;
  name: string;
  active: number;
  all_areas: number;
  default_area_key: string | null;
  break_preference: string;
};

type Area = { key: string; label: string };

type Permission = { member_id: number; area_key: string };

const notice = Astro.url.searchParams.get('notice');
const errorMsg = Astro.url.searchParams.get('error');

let members: Member[] = [];
let areas: Area[] = [];
let perms: Permission[] = [];
let dbError: string | null = null;

try {
  const DB = await getDB();
  const [memberRows, areaRows, permissionRows] = await Promise.all([
    loadMembers(DB, { includeBreakPreference: true }),
    loadAreas(DB),
    loadPermissions(DB)
  ]);
  members = memberRows as Member[];
  areas = areaRows.map((row) => ({ key: row.key, label: row.label }));
  perms = permissionRows as Permission[];
} catch (e: any) {
  dbError = e?.message ?? String(e);
}

function allowedAreasFor(memberId: number) {
  return perms.filter((p) => p.member_id === memberId).map((p) => p.area_key);
}

function areaLabel(areaKey: string | null) {
  if (!areaKey) return '—';
  return areas.find((area) => area.key === areaKey)?.label ?? areaKey;
}
---

<Layout title="Members | Bunrun">
  <div class="mx-auto max-w-[96rem] px-3 py-10">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight">Members</h1>
        <p class="mt-2 text-slate-700">Manage members, allowed areas, default area, and break preferences.</p>
      </div>
      <button
        class="rounded-lg bg-emerald-700 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-800"
        type="button"
        data-open-add-member
      >
        Add member
      </button>
    </div>

    {errorMsg && (
      <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 p-4 text-rose-900">
        <div class="font-semibold">Action blocked</div>
        <div class="mt-1 text-sm">{errorMsg}</div>
      </div>
    )}

    {notice && (
      <div class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900">
        <div class="font-semibold">Updated</div>
        <div class="mt-1 text-sm">{notice}</div>
      </div>
    )}

    {dbError ? (
      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-5 text-amber-900">
        <div class="font-medium">DB not configured yet</div>
        <div class="mt-2 text-sm">{dbError}</div>
      </div>
    ) : (
      <div class="mt-6 space-y-4">
        {members.map((member) => {
          const allowed = allowedAreasFor(member.id);
          const allowedLabels = allowed.map((key) => areaLabel(key)).sort((a, b) => a.localeCompare(b));
          return (
            <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
              <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                  <div class="text-lg font-semibold">{member.name}</div>
                  <div class="mt-1 text-sm text-slate-600">
                    Status: {member.active ? 'Active' : 'Inactive'}
                    {' · '}
                    Areas: {member.all_areas ? 'All areas' : 'Restricted'}
                    {' · '}
                    Default area: {areaLabel(member.default_area_key)}
                    {' · '}
                    Break preference: {member.break_preference}
                  </div>
                  {!member.all_areas && (
                    <div class="mt-1 text-sm text-slate-600">
                      Allowed: {allowedLabels.join(', ') || '—'}
                    </div>
                  )}
                </div>

                <div class="flex flex-wrap items-center gap-2">
                  <form method="post" action="/api/members/toggle-active">
                    <input type="hidden" name="memberId" value={member.id} />
                    <input type="hidden" name="active" value={member.active ? '0' : '1'} />
                    <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" type="submit">
                      {member.active ? 'Deactivate' : 'Reactivate'}
                    </button>
                  </form>

                  <form method="post" action="/api/members/set-all-areas">
                    <input type="hidden" name="memberId" value={member.id} />
                    <input type="hidden" name="allAreas" value="1" />
                    <button
                      class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50"
                      type="submit"
                      disabled={!member.active}
                    >
                      Allow all areas
                    </button>
                  </form>

                  <button
                    class="rounded-lg bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-800"
                    type="button"
                    data-open-edit-member
                    data-member-id={member.id}
                    data-name={member.name}
                    data-default-area={member.default_area_key ?? ''}
                    data-break-preference={member.break_preference}
                    data-all-areas={member.all_areas}
                    data-active={member.active}
                    data-areas={allowed.join(',')}
                  >
                    Modify
                  </button>
                </div>
              </div>
            </section>
          );
        })}
      </div>
    )}
  </div>

  <dialog class="w-full max-w-3xl rounded-2xl border border-slate-200 p-0 shadow-2xl backdrop:bg-slate-900/40" data-member-dialog="add">
    <form class="p-6" method="post" action="/api/members/add">
      <input type="hidden" name="returnTo" value="/admin/members" />
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="text-xl font-semibold">Add member</h2>
          <p class="mt-1 text-sm text-slate-600">Create a member and set their areas and break preference in one step.</p>
        </div>
        <button class="rounded-lg border border-slate-300 px-3 py-2 text-sm hover:bg-slate-50" type="button" data-close-dialog>Cancel</button>
      </div>

      <div class="mt-5 grid gap-4 sm:grid-cols-3">
        <label class="block">
          <div class="text-sm font-medium text-slate-800">Name</div>
          <input class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="name" required />
        </label>

        <label class="block">
          <div class="text-sm font-medium text-slate-800">Default area</div>
          <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="defaultAreaKey">
            <option value="">—</option>
            {areas.map((area) => (
              <option value={area.key}>{area.label}</option>
            ))}
          </select>
        </label>

        <label class="block">
          <div class="text-sm font-medium text-slate-800">Break preference</div>
          <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="breakPreference">
            {BREAK_PREFERENCES.map((pref) => (
              <option value={pref} selected={pref === '15+30'}>{pref}</option>
            ))}
          </select>
        </label>
      </div>

      <div class="mt-5">
        <div class="text-sm font-medium text-slate-800">Allowed areas</div>
        <div class="mt-1 text-sm text-slate-600">Select the areas this member is allowed to work.</div>
        <div class="mt-3 grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
          {areas.map((area) => (
            <label class="flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm">
              <input type="checkbox" name="areas" value={area.key} checked />
              <span>{area.label}</span>
            </label>
          ))}
        </div>
      </div>

      <div class="mt-6 flex justify-end gap-3">
        <button class="rounded-lg border border-slate-300 bg-white px-4 py-2 hover:bg-slate-50" type="button" data-close-dialog>Cancel</button>
        <button class="rounded-lg bg-emerald-700 px-4 py-2 font-medium text-white hover:bg-emerald-800" type="submit">Add member</button>
      </div>
    </form>
  </dialog>

  <dialog class="w-full max-w-3xl rounded-2xl border border-slate-200 p-0 shadow-2xl backdrop:bg-slate-900/40" data-member-dialog="edit">
    <form class="p-6" method="post" action="/api/members/update">
      <input type="hidden" name="memberId" />
      <input type="hidden" name="returnTo" value="/admin/members" />
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="text-xl font-semibold">Modify member</h2>
          <p class="mt-1 text-sm text-slate-600">Update member details and permissions without leaving the list.</p>
        </div>
        <button class="rounded-lg border border-slate-300 px-3 py-2 text-sm hover:bg-slate-50" type="button" data-close-dialog>Cancel</button>
      </div>

      <div class="mt-5 grid gap-4 sm:grid-cols-3">
        <label class="block">
          <div class="text-sm font-medium text-slate-800">Name</div>
          <input class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="name" required />
        </label>

        <label class="block">
          <div class="text-sm font-medium text-slate-800">Default area</div>
          <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="defaultAreaKey">
            <option value="">—</option>
            {areas.map((area) => (
              <option value={area.key}>{area.label}</option>
            ))}
          </select>
        </label>

        <label class="block">
          <div class="text-sm font-medium text-slate-800">Break preference</div>
          <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="breakPreference">
            {BREAK_PREFERENCES.map((pref) => (
              <option value={pref}>{pref}</option>
            ))}
          </select>
        </label>
      </div>

      <div class="mt-5">
        <div class="text-sm font-medium text-slate-800">Allowed areas</div>
        <div class="mt-1 text-sm text-slate-600">Applies to home area, shift allocation, and break coverage.</div>
        <div class="mt-3 grid gap-2 sm:grid-cols-2 lg:grid-cols-4" data-edit-areas>
          {areas.map((area) => (
            <label class="flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm">
              <input type="checkbox" name="areas" value={area.key} />
              <span>{area.label}</span>
            </label>
          ))}
        </div>
      </div>

      <div class="mt-6 flex justify-end gap-3">
        <button class="rounded-lg border border-slate-300 bg-white px-4 py-2 hover:bg-slate-50" type="button" data-close-dialog>Cancel</button>
        <button class="rounded-lg bg-slate-900 px-4 py-2 font-medium text-white hover:bg-slate-800" type="submit">Save</button>
      </div>
    </form>
  </dialog>

  <script is:inline>
    const memberDialogs = {
      add: document.querySelector('[data-member-dialog="add"]'),
      edit: document.querySelector('[data-member-dialog="edit"]')
    };

    const showMemberDialog = (dialog) => dialog && typeof dialog.showModal === 'function' && dialog.showModal();
    const closeMemberDialog = (dialog) => dialog && typeof dialog.close === 'function' && dialog.close();

    document.querySelector('[data-open-add-member]')?.addEventListener('click', () => showMemberDialog(memberDialogs.add));

    document.querySelectorAll('[data-close-dialog]').forEach((button) => {
      button.addEventListener('click', () => closeMemberDialog(button.closest('dialog')));
    });

    document.querySelectorAll('[data-open-edit-member]').forEach((button) => {
      button.addEventListener('click', () => {
        const dialog = memberDialogs.edit;
        if (!dialog) return;

        const selectedAreas = new Set((button.dataset.areas || '').split(',').filter(Boolean));
        const allAreas = button.dataset.allAreas === '1';

        dialog.querySelector('input[name="memberId"]').value = button.dataset.memberId || '';
        dialog.querySelector('input[name="name"]').value = button.dataset.name || '';
        dialog.querySelector('select[name="defaultAreaKey"]').value = button.dataset.defaultArea || '';
        dialog.querySelector('select[name="breakPreference"]').value = button.dataset.breakPreference || '15+30';

        dialog.querySelectorAll('input[name="areas"]').forEach((input) => {
          input.checked = allAreas || selectedAreas.has(input.value);
        });

        showMemberDialog(dialog);
      });
    });
  </script>
</Layout>
