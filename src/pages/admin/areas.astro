---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { requireRole } from '../../lib/auth';
import { getDB } from '../../lib/db';

const guard = requireRole(Astro.request, 'admin');
if (!guard.ok) return guard.redirect;

type Area = { key: string; label: string; min_staff: number };

const notice = Astro.url.searchParams.get('notice');
const errorMsg = Astro.url.searchParams.get('error');

const DB = await getDB();
const areas = (await DB.prepare('SELECT key, label, min_staff FROM areas ORDER BY label COLLATE NOCASE ASC').all()).results as Area[];
---

<Layout title="Areas | Bunrun">
  <div class="mx-auto max-w-4xl px-4 py-10">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight">Areas</h1>
        <p class="mt-2 text-slate-700">Rename areas and set minimum staffing levels used by break planning.</p>
      </div>
      <a class="text-sm underline" href="/admin">Back</a>
    </div>

    {errorMsg && (
      <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 p-4 text-rose-900">
        <div class="font-semibold">Action blocked</div>
        <div class="mt-1 text-sm">{errorMsg}</div>
      </div>
    )}

    {notice && (
      <div class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900">
        <div class="font-semibold">Updated</div>
        <div class="mt-1 text-sm">{notice}</div>
      </div>
    )}

    <div class="mt-6 space-y-4">
      {areas.map((area) => (
        <form class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm" method="post" action="/api/areas/update">
          <input type="hidden" name="key" value={area.key} />
          <div class="grid gap-4 sm:grid-cols-[1.4fr_0.8fr_auto]">
            <label class="block">
              <div class="text-sm font-medium text-slate-800">Area name</div>
              <input class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="label" value={area.label} required />
            </label>
            <label class="block">
              <div class="text-sm font-medium text-slate-800">Minimum staff</div>
              <input class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" type="number" name="minStaff" min="0" max="99" value={area.min_staff} required />
            </label>
            <div class="flex items-end">
              <button class="rounded-lg bg-slate-900 px-4 py-2 font-medium text-white hover:bg-slate-800" type="submit">
                Save
              </button>
            </div>
          </div>
          <div class="mt-2 text-xs text-slate-500">Key: {area.key}</div>
        </form>
      ))}
    </div>
  </div>
</Layout>
