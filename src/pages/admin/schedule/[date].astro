---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { requireRole } from '../../../lib/auth';
import { getDB } from '../../../lib/db';
import { formatDurationMinutes, operatingHoursFor, parseHHMM } from '../../../lib/time';
import { breakAllowanceMinutes } from '../../../lib/breaks';
import { addDays, formatLongDateLabel, formatShortDateLabel, startOfWeek, weekDatesFor } from '../../../lib/schedule';
import {
  activeWorkingShiftForMember,
  breakTargetRange,
  buildPlannerContext,
  isCoverAssignmentValid,
  listEligibleCoverOptions,
  type PlannerBreak
} from '../../../lib/break-planner';
import { activeShiftAtTime } from '../../../lib/work-blocks';
import Runsheet from '../../../components/Runsheet.astro';

const guard = requireRole(Astro.request, 'admin');
if (!guard.ok) return guard.redirect;

const date = Astro.params.date ?? '';
if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) {
  return new Response('Invalid date', { status: 400 });
}

type Member = {
  id: number;
  name: string;
  active: number;
  all_areas: number;
  default_area_key: string | null;
};

type Area = { key: string; label: string; min_staff?: number };

type ShiftRow = {
  id: number;
  work_block_id: number | null;
  member_id: number;
  name: string;
  home_area_key: string;
  status_key: string;
  shift_role: string;
  start_time: string;
  end_time: string | null;
  shift_minutes: number;
};

type BreakRow = {
  id: number;
  work_block_id: number | null;
  shift_id: number;
  start_time: string;
  duration_minutes: number;
  cover_member_id: number | null;
  cover_member_name: string | null;
};

type WorkBlockRow = {
  id: number;
  schedule_id: number;
  member_id: number;
  member_name: string;
  start_time: string;
  end_time: string;
  total_minutes: number;
};

type Status = { key: string; label: string; blocks_coverage: number };

type WeekSummary = {
  date: string;
  shift_count: number;
  working_count: number;
};

type ShiftView = ShiftRow & {
  start_minutes: number;
  end_minutes: number | null;
  computed_minutes: number;
  warnings: string[];
  status_label: string;
  role_label: string;
  area_label: string;
  preferred_coverer_names: string[];
};

type BreakListRow = {
  id: number;
  work_block_id: number | null;
  start_time: string;
  duration_minutes: number;
  off_member_name: string;
  off_area_label: string;
  cover_member_name: string | null;
  cover_shift_role: string | null;
};

const breakPanelBaseUrl = `/admin/schedule/${date}?panel=breaks`;
const showBreakPlanning = Astro.url.searchParams.get('panel') === 'breaks';

const DB = await getDB();

// Ensure schedule exists
await DB.prepare('INSERT OR IGNORE INTO schedules (date) VALUES (?)').bind(date).run();
const schedule = (await DB.prepare('SELECT id, date FROM schedules WHERE date=?').bind(date).first()) as any;
const scheduleId = schedule.id as number;

const shifts = (await DB.prepare(
  `SELECT s.id, s.work_block_id, s.member_id, m.name, s.home_area_key, s.status_key, s.shift_role, s.start_time, s.end_time, s.shift_minutes
   FROM shifts s
   JOIN members m ON m.id = s.member_id
   WHERE s.schedule_id=?
   ORDER BY s.home_area_key ASC, m.name COLLATE NOCASE ASC`
).bind(scheduleId).all()).results as ShiftRow[];

const breaks = (await DB.prepare(
  `SELECT b.id, b.work_block_id, b.shift_id, b.start_time, b.duration_minutes, b.cover_member_id,
          coverm.name AS cover_member_name
   FROM breaks b
   JOIN shifts s ON s.id = b.shift_id
   LEFT JOIN members coverm ON coverm.id = b.cover_member_id
   WHERE s.schedule_id=?
   ORDER BY b.start_time ASC`
).bind(scheduleId).all()).results as BreakRow[];

const workBlocks = (await DB.prepare(
  `SELECT wb.id, wb.schedule_id, wb.member_id, m.name AS member_name, wb.start_time, wb.end_time, wb.total_minutes
   FROM work_blocks wb
   JOIN members m ON m.id = wb.member_id
   WHERE wb.schedule_id=?
   ORDER BY wb.start_time ASC, m.name COLLATE NOCASE ASC`
).bind(scheduleId).all()).results as WorkBlockRow[];

const breaksByShift = new Map<number, BreakRow[]>();
for (const b of breaks) {
  const arr = breaksByShift.get(b.shift_id) ?? [];
  arr.push(b);
  breaksByShift.set(b.shift_id, arr);
}
const breaksByWorkBlock = new Map<number, BreakRow[]>();
for (const b of breaks) {
  if (b.work_block_id == null) continue;
  const arr = breaksByWorkBlock.get(b.work_block_id) ?? [];
  arr.push(b);
  breaksByWorkBlock.set(b.work_block_id, arr);
}

const members = (await DB.prepare(
  'SELECT id, name, active, all_areas, default_area_key FROM members WHERE active=1 ORDER BY name COLLATE NOCASE ASC'
).all()).results as Member[];

const areas = (await DB.prepare('SELECT key, label, min_staff FROM areas ORDER BY label COLLATE NOCASE ASC').all()).results as Area[];

const statuses = (await DB.prepare('SELECT key, label, blocks_coverage FROM statuses ORDER BY label COLLATE NOCASE ASC').all())
  .results as Status[];
const shiftCoverPriorityRows = (
  await DB.prepare(
    `SELECT scp.shift_id, scp.member_id, scp.priority, m.name
     FROM shift_cover_priorities scp
     JOIN members m ON m.id = scp.member_id
     ORDER BY scp.shift_id ASC, scp.priority ASC`
  ).all()
).results as Array<{ shift_id: number; member_id: number; priority: number; name: string }>;

const perms = (await DB.prepare('SELECT member_id, area_key FROM member_area_permissions').all()).results as any[];
const permsByMember = new Map<number, Set<string>>();
for (const p of perms) {
  const set = permsByMember.get(p.member_id) ?? new Set<string>();
  set.add(p.area_key);
  permsByMember.set(p.member_id, set);
}

const memberById = new Map(members.map((m) => [m.id, m]));
const areaByKey = new Map(areas.map((a) => [a.key, a]));
const statusByKey = new Map(statuses.map((s) => [s.key, s]));
const shiftById = new Map(shifts.map((s) => [s.id, s]));
const workBlockById = new Map(workBlocks.map((block) => [block.id, block]));
const preferredCovererIdsByShift = new Map<number, number[]>();
const preferredCovererNamesByShift = new Map<number, string[]>();
const preferredRankByShiftId = new Map<number, Map<number, number>>();
for (const row of shiftCoverPriorityRows) {
  const ids = preferredCovererIdsByShift.get(row.shift_id) ?? [];
  ids.push(row.member_id);
  preferredCovererIdsByShift.set(row.shift_id, ids);

  const names = preferredCovererNamesByShift.get(row.shift_id) ?? [];
  names.push(row.name);
  preferredCovererNamesByShift.set(row.shift_id, names);
}
for (const [shiftId, ids] of preferredCovererIdsByShift.entries()) {
  preferredRankByShiftId.set(shiftId, new Map(ids.map((memberId, index) => [memberId, index])));
}
const op = operatingHoursFor(date);
const areaMinByKey = new Map(areas.map((a: any) => [a.key, Number((a as any).min_staff ?? 0)]));
const workingShifts = shifts.filter((s) => s.status_key === 'working');
const workingWorkBlockIds = new Set(workBlocks.map((block) => block.id));
const uncoveredBreaks = breaks.filter((b) => (b.work_block_id != null ? workingWorkBlockIds.has(b.work_block_id) : true) && b.cover_member_id == null);

// base working counts per area
const shiftViews = shifts.map((s) => {
  const startMinutes = parseHHMM(s.start_time) ?? 0;
  const endMinutes = s.end_time ? parseHHMM(s.end_time) : null;
  const computedMinutes = endMinutes != null ? endMinutes - startMinutes : s.shift_minutes;
  return {
    ...s,
    start_minutes: startMinutes,
    end_minutes: endMinutes,
    computed_minutes: computedMinutes,
    warnings: endMinutes != null ? warningsForShift(s.start_time, s.end_time!, computedMinutes) : [],
    status_label: statusByKey.get(s.status_key)?.label ?? s.status_key,
    role_label: s.shift_role === 'floater' ? 'Floater' : 'Normal',
    area_label: areaByKey.get(s.home_area_key)?.label ?? s.home_area_key,
    preferred_coverer_names: preferredCovererNamesByShift.get(s.id) ?? []
  } satisfies ShiftView;
});
const shiftViewById = new Map(shiftViews.map((s) => [s.id, s]));
const shiftViewsByWorkBlock = new Map<number, ShiftView[]>();
for (const shift of shiftViews) {
  if (shift.work_block_id == null) continue;
  const arr = shiftViewsByWorkBlock.get(shift.work_block_id) ?? [];
  arr.push(shift);
  shiftViewsByWorkBlock.set(shift.work_block_id, arr);
}
for (const arr of shiftViewsByWorkBlock.values()) {
  arr.sort((a, b) => a.start_time.localeCompare(b.start_time) || a.id - b.id);
}
const breakPanelUrl = `${breakPanelBaseUrl}#breaks`;
const breakPlanningBlocks = workBlocks
  .map((block) => ({
    ...block,
    shifts: shiftViewsByWorkBlock.get(block.id) ?? []
  }))
  .filter((block) => block.shifts.length > 0);
const breakPlanningBlockIds = new Set(breakPlanningBlocks.map((block) => block.id));
const planner = buildPlannerContext({
  shifts: shifts.map((shift) => ({
    id: shift.id,
    member_id: shift.member_id,
    home_area_key: shift.home_area_key,
    status_key: shift.status_key,
    shift_role: shift.shift_role,
    start_time: shift.start_time,
    end_time: shift.end_time
  })),
  members: members.map((member) => ({
    id: member.id,
    all_areas: member.all_areas
  })),
  perms,
  minByArea: areaMinByKey,
  preferredRankByShiftId
});
const plannerBreaks: PlannerBreak[] = breaks.flatMap((b) => {
  const offShift = shiftById.get(b.shift_id);
  if (!offShift) return [];
  return [{
    id: b.id,
    work_block_id: b.work_block_id,
    shift_id: b.shift_id,
    start_time: b.start_time,
    duration_minutes: Number(b.duration_minutes),
    cover_member_id: b.cover_member_id,
    off_member_id: offShift.member_id,
    off_shift_id: offShift.id,
    off_area_key: offShift.home_area_key
  }];
});
const plannedBreakMinutesByWorkBlock = new Map<number, number>();
for (const [workBlockId, rows] of breaksByWorkBlock.entries()) {
  plannedBreakMinutesByWorkBlock.set(
    workBlockId,
    rows.reduce((sum, row) => sum + Number(row.duration_minutes), 0)
  );
}

const invalidCoverBreaks: { id: number; reason: string }[] = [];
if (showBreakPlanning) {
  for (const b of plannerBreaks) {
    if (b.work_block_id == null || !breakPlanningBlockIds.has(b.work_block_id)) continue;
    if (b.cover_member_id == null) continue;
    if (!isCoverAssignmentValid(planner, plannerBreaks, b, b.cover_member_id)) {
      invalidCoverBreaks.push({ id: b.id, reason: 'Cover assignment needs review' });
    }
  }
}

const invalidReasonByBreakId = new Map(invalidCoverBreaks.map((x) => [x.id, x.reason]));
const chronologicalBreakRows = plannerBreaks
  .map((row) => {
    const offShift = shiftById.get(row.shift_id);
    const offMember = offShift ? memberById.get(offShift.member_id) : null;
    const coverMember = row.cover_member_id != null ? memberById.get(row.cover_member_id) : null;
    const coverShift = row.cover_member_id != null
      ? activeWorkingShiftForMember(planner, row.cover_member_id, breakTargetRange(row) ?? { start: -1, end: -1 })
      : null;
    return {
      id: row.id,
      work_block_id: row.work_block_id,
      start_time: row.start_time,
      duration_minutes: row.duration_minutes,
      off_member_name: offMember?.name ?? 'Unknown member',
      off_area_label: areaByKey.get(row.off_area_key)?.label ?? row.off_area_key,
      cover_member_name: coverMember?.name ?? null,
      cover_shift_role: coverShift?.shift_role ?? null
    } satisfies BreakListRow;
  })
  .sort((a, b) => (parseHHMM(a.start_time) ?? 0) - (parseHHMM(b.start_time) ?? 0) || a.off_member_name.localeCompare(b.off_member_name));

const notice = Astro.url.searchParams.get('notice');
const errorMsg = Astro.url.searchParams.get('error');
const weekStart = startOfWeek(date);
const weekDates = weekDatesFor(date);
const previousWeekDate = addDays(weekStart, -7);
const nextWeekDate = addDays(weekStart, 7);
const weekEnd = weekDates[6] ?? date;
const weekSummaryRows = (
  await DB.prepare(
    `SELECT sc.date,
            COUNT(sh.id) AS shift_count,
            SUM(CASE WHEN sh.status_key='working' THEN 1 ELSE 0 END) AS working_count
     FROM schedules sc
     LEFT JOIN shifts sh ON sh.schedule_id = sc.id
     WHERE sc.date >= ? AND sc.date <= ?
     GROUP BY sc.date`
  )
    .bind(weekStart, weekEnd)
    .all()
).results as WeekSummary[];
const weekSummaryByDate = new Map(
  weekSummaryRows.map((row) => [
    row.date,
    {
      shiftCount: Number(row.shift_count ?? 0),
      workingCount: Number(row.working_count ?? 0)
    }
  ])
);

function warningsForShift(start: string, end: string, minutes: number): string[] {
  const out: string[] = [];
  if (minutes > 9 * 60) out.push('Long shift (> 9h)');
  if (minutes > 10 * 60) out.push('Shift exceeds 10h max');
  if (op) {
    const s = parseHHMM(start);
    const e = parseHHMM(end);
    if (s != null && e != null) {
      if (s < op.open || e > op.close) out.push('Outside operating hours');
    }
  }
  return out;
}

function coverCandidatesForBreak(offShift: ShiftView, targetBreak: BreakRow) {
  const plannerBreak = plannerBreaks.find((row) => row.id === targetBreak.id);
  if (!plannerBreak) return [];
  const validIds = new Set(
    listEligibleCoverOptions(planner, plannerBreaks, plannerBreak)
      .map((row) => row.memberId)
      .filter((value): value is number => value != null)
  );
  return members
    .filter((member) => validIds.has(member.id))
    .sort((a, b) => {
      const ranks = preferredRankByShiftId.get(offShift.id) ?? new Map<number, number>();
      const aRank = ranks.get(a.id) ?? Number.MAX_SAFE_INTEGER;
      const bRank = ranks.get(b.id) ?? Number.MAX_SAFE_INTEGER;
      const targetRange = plannerBreak ? breakTargetRange(plannerBreak) : null;
      const aFloater = targetRange
        ? activeWorkingShiftForMember(planner, a.id, targetRange)?.shift_role === 'floater'
        : false;
      const bFloater = targetRange
        ? activeWorkingShiftForMember(planner, b.id, targetRange)?.shift_role === 'floater'
        : false;
      if (aFloater !== bFloater) return aFloater ? -1 : 1;
      if (aRank !== bRank) return aRank - bRank;
      const aSameArea = workingShifts.some((shift) => shift.member_id === a.id && shift.home_area_key === offShift.home_area_key);
      const bSameArea = workingShifts.some((shift) => shift.member_id === b.id && shift.home_area_key === offShift.home_area_key);
      if (aSameArea !== bSameArea) return aSameArea ? -1 : 1;
      return a.name.localeCompare(b.name);
    });
}

const coverCandidatesByBreakId = new Map<number, Member[]>();
if (showBreakPlanning) {
  for (const block of breakPlanningBlocks) {
    for (const b of breaksByWorkBlock.get(block.id) ?? []) {
      const offShift = shiftViewById.get(b.shift_id);
      if (!offShift) continue;
      coverCandidatesByBreakId.set(b.id, coverCandidatesForBreak(offShift, b));
    }
  }
}
---

<Layout title={`Schedule ${date} | Bunrun`}>
  <script src="/js/schedule-time.js?v=4" defer></script>
  <div class="mx-auto max-w-[96rem] px-3 py-10">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight">Schedule</h1>
        <div class="mt-1 text-slate-700">{formatLongDateLabel(date)}</div>
        <div class="mt-1 text-sm text-slate-500">Week of {weekStart}</div>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href="/admin/schedule">Change date</a>
        <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href={`/admin/schedule/${previousWeekDate}`}>
          Previous week
        </a>
        <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href={`/admin/schedule/${nextWeekDate}`}>
          Next week
        </a>
      </div>
    </div>

    <div class="mt-6 overflow-x-auto">
      <div class="flex min-w-max gap-3">
        {weekDates.map((tabDate) => {
          const summary = weekSummaryByDate.get(tabDate) ?? { shiftCount: 0, workingCount: 0 };
          const active = tabDate === date;
          return (
            <a
              class:list={[
                'min-w-[132px] rounded-2xl border px-4 py-3 text-left transition',
                active
                  ? 'border-emerald-600 bg-emerald-50 text-emerald-950 shadow-sm'
                  : 'border-slate-200 bg-white text-slate-800 hover:border-slate-300 hover:bg-slate-50'
              ]}
              href={`/admin/schedule/${tabDate}`}
            >
              <div class="text-sm font-semibold">{formatShortDateLabel(tabDate)}</div>
              <div class="mt-1 text-xs text-slate-600">
                {summary.shiftCount} shift{summary.shiftCount === 1 ? '' : 's'}
              </div>
              <div class="mt-0.5 text-xs text-slate-500">
                {summary.workingCount} working
              </div>
            </a>
          );
        })}
      </div>
    </div>

    {op && (
      <div class="mt-3 text-sm text-slate-600">
        Operating hours: {Math.floor(op.open / 60).toString().padStart(2, '0')}:{String(op.open % 60).padStart(2, '0')}
        – {Math.floor(op.close / 60).toString().padStart(2, '0')}:{String(op.close % 60).padStart(2, '0')}
      </div>
    )}

    {errorMsg && (
      <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 p-4 text-rose-900">
        <div class="font-semibold">Action blocked</div>
        <div class="mt-1 text-sm">{errorMsg}</div>
      </div>
    )}

    {notice && (
      <div class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900">
        <div class="font-semibold">Updated</div>
        <div class="mt-1 text-sm">{notice}</div>
      </div>
    )}

    {(uncoveredBreaks.length > 0 || invalidCoverBreaks.length > 0) && (
      <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 p-4 text-rose-900">
        <div class="font-semibold">Schedule needs attention</div>
        <div class="mt-1 text-sm">
          {uncoveredBreaks.length > 0 && (
            <span>
              {uncoveredBreaks.length} break{uncoveredBreaks.length === 1 ? '' : 's'} {uncoveredBreaks.length === 1 ? 'is' : 'are'} missing cover.
            </span>
          )}
          {invalidCoverBreaks.length > 0 && (
            <span class="ml-2">
              {invalidCoverBreaks.length} break{invalidCoverBreaks.length === 1 ? '' : 's'} {invalidCoverBreaks.length === 1 ? 'has' : 'have'} invalid cover.
            </span>
          )}
          <a class="ml-2 underline" href={breakPanelUrl}>Review break planning</a>
        </div>
      </div>
    )}

    <div class="mt-8 grid gap-4 xl:grid-cols-2">
      <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-medium">Copy day</h2>
        <p class="mt-2 text-sm text-slate-600">Replace this day's shifts and breaks with another date.</p>
        <form class="mt-4 flex flex-wrap items-end gap-3" method="post" action="/api/schedule/copy-day" onsubmit={`return confirm('Copy the selected day into ${date}? This overwrites the current day.')`}>
          <input type="hidden" name="targetDate" value={date} />
          <label class="block">
            <div class="text-sm font-medium text-slate-800">Source day</div>
            <input class="mt-1 rounded-lg border border-slate-300 bg-white px-3 py-2" type="date" name="sourceDate" value={addDays(date, -7)} required />
          </label>
          <button class="rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800" type="submit">
            Copy into {date}
          </button>
        </form>
      </section>

      <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-medium">Copy week</h2>
        <p class="mt-2 text-sm text-slate-600">Replace every day in this week with the matching day from another week.</p>
        <form class="mt-4 flex flex-wrap items-end gap-3" method="post" action="/api/schedule/copy-week" onsubmit={`return confirm('Copy the selected week into the week of ${weekStart}? This overwrites all 7 days.')`}>
          <input type="hidden" name="targetWeekDate" value={weekStart} />
          <label class="block">
            <div class="text-sm font-medium text-slate-800">Source week</div>
            <input class="mt-1 rounded-lg border border-slate-300 bg-white px-3 py-2" type="date" name="sourceWeekDate" value={addDays(weekStart, -7)} required />
          </label>
          <button class="rounded-lg bg-emerald-700 px-4 py-2.5 text-sm font-medium text-white hover:bg-emerald-800" type="submit">
            Copy into week of {weekStart}
          </button>
        </form>
      </section>
    </div>

    <div class="mt-8 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <h2 class="text-lg font-medium">Shifts</h2>
        <button
          class="rounded-lg bg-emerald-700 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-800"
          type="button"
          data-open-add-shift
        >
          Add to Shift
        </button>
      </div>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full min-w-[980px] border-separate border-spacing-y-2 text-sm">
          <thead>
            <tr class="text-left text-slate-600">
              <th class="px-3">Member</th>
              <th class="px-3">Area</th>
              <th class="px-3">Role</th>
              <th class="px-3">Status</th>
              <th class="px-3">Start</th>
              <th class="px-3">End</th>
              <th class="px-3">Length</th>
              <th class="px-3">Warnings</th>
              <th class="px-3"></th>
            </tr>
          </thead>
          <tbody>
            {shiftViews.map((s) => {
              return (
                <tr class="bg-slate-50">
                  <td class="px-3 py-3 font-medium">{s.name}</td>
                  <td class="px-3 py-3">{s.area_label}</td>
                  <td class="px-3 py-3">
                    {s.shift_role === 'floater' ? (
                      <span class="rounded-full bg-sky-100 px-2 py-1 text-xs font-semibold text-sky-900">Floater</span>
                    ) : (
                      <span class="text-slate-500">Normal</span>
                    )}
                  </td>
                  <td class="px-3 py-3">
                    {s.status_key === 'sick' ? (
                      <span class="rounded bg-rose-100 px-2 py-1 font-medium text-rose-900">Sick</span>
                    ) : (
                      s.status_label
                    )}
                  </td>
                  <td class="px-3 py-3">{s.start_time}</td>
                  <td class="px-3 py-3">{s.end_time ?? '—'}</td>
                  <td class="px-3 py-3">{formatDurationMinutes(s.computed_minutes)}</td>
                  <td class="px-3 py-3">
                    {s.warnings.length ? (
                      <span class="rounded bg-amber-100 px-2 py-1 text-amber-900">{s.warnings.join(' · ')}</span>
                    ) : (
                      <span class="text-slate-500">—</span>
                    )}
                    {s.preferred_coverer_names.length > 0 && (
                      <div class="mt-2 text-xs text-slate-500">Preferred coverers: {s.preferred_coverer_names.join(' → ')}</div>
                    )}
                  </td>
                  <td class="px-3 py-3">
                    <div class="flex items-center gap-2">
                      <button
                        class="rounded-lg border border-slate-300 bg-white px-3 py-2 hover:bg-slate-100"
                        type="button"
                        data-open-edit-shift
                        data-shift-id={s.id}
                        data-member-id={s.member_id}
                        data-member-name={s.name}
                        data-home-area-key={s.home_area_key}
                        data-status-key={s.status_key}
                        data-shift-role={s.shift_role}
                        data-start-time={s.start_time}
                        data-end-time={s.end_time ?? ''}
                        data-preferred-coverers={(preferredCovererIdsByShift.get(s.id) ?? []).join(',')}
                      >
                        Modify
                      </button>
                      <form method="post" action="/api/shifts/delete" onsubmit="return confirm('Delete this shift?')">
                        <input type="hidden" name="shiftId" value={s.id} />
                        <input type="hidden" name="date" value={date} />
                        <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 hover:bg-slate-100" type="submit">
                          Delete
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      {shifts.length === 0 && <div class="mt-4 text-sm text-slate-600">No shifts yet.</div>}
    </div>

    <dialog class="w-full max-w-4xl rounded-2xl border border-slate-200 p-0 shadow-2xl backdrop:bg-slate-900/40" data-shift-dialog="add">
      <form class="p-6" method="post" action="/api/shifts/upsert" data-shift-form>
        <input type="hidden" name="date" value={date} />
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-xl font-semibold">Add member to shift</h2>
            <p class="mt-1 text-sm text-slate-600">Add a member to the selected day without leaving the schedule page.</p>
          </div>
          <button class="rounded-lg border border-slate-300 px-3 py-2 text-sm hover:bg-slate-50" type="button" data-close-shift-dialog>Cancel</button>
        </div>

        <div class="mt-5 grid gap-4">
          <label class="block max-w-sm">
            <div class="text-sm font-medium text-slate-800">Member</div>
            <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="memberId" required data-bunrun-member>
              <option value="" selected>Select…</option>
              {members.map((m) => (
                <option value={m.id} data-default-area={m.default_area_key ?? ''}>{m.name}</option>
              ))}
            </select>
          </label>

          <div class="grid gap-4 sm:grid-cols-5">
            <label class="block">
              <div class="text-sm font-medium text-slate-800">Area</div>
              <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="homeAreaKey" required data-bunrun-area>
                {areas.map((a) => (
                  <option value={a.key}>{a.label}</option>
                ))}
              </select>
            </label>

            <label class="block">
              <div class="text-sm font-medium text-slate-800">Status</div>
              <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="statusKey" required>
                {statuses.map((s) => (
                  <option value={s.key} selected={s.key === 'working'}>{s.label}</option>
                ))}
              </select>
            </label>

            <label class="block">
              <div class="text-sm font-medium text-slate-800">Role</div>
              <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="shiftRole">
                <option value="normal" selected>Normal</option>
                <option value="floater">Floater</option>
              </select>
              <div class="mt-1 text-xs text-slate-500">Floaters are prioritised to cover other members where possible.</div>
            </label>

            <label class="block">
              <div class="text-sm font-medium text-slate-800">Start</div>
              <input class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" type="time" name="startTime" value="06:00" required step="60" />
            </label>

            <label class="block">
              <div class="text-sm font-medium text-slate-800">End</div>
              <input class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" type="time" name="endTime" value="15:00" required step="60" data-bunrun-endtime />
            </label>
          </div>
        </div>

        <div id="shiftComputed" class="mt-4 text-sm text-slate-600"></div>

        <div class="mt-6 flex justify-end gap-3">
          <button class="rounded-lg border border-slate-300 bg-white px-4 py-2 hover:bg-slate-50" type="button" data-close-shift-dialog>Cancel</button>
          <button class="rounded-lg bg-emerald-700 px-4 py-2 font-medium text-white hover:bg-emerald-800" type="submit" data-bunrun-add-shift>Submit</button>
        </div>
      </form>
    </dialog>

    <dialog class="w-full max-w-4xl rounded-2xl border border-slate-200 p-0 shadow-2xl backdrop:bg-slate-900/40" data-shift-dialog="edit">
      <form class="p-6" method="post" action="/api/shifts/update" data-shift-form>
        <input type="hidden" name="date" value={date} />
        <input type="hidden" name="shiftId" />
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-xl font-semibold">Edit shift</h2>
            <p class="mt-1 text-sm text-slate-600" data-edit-shift-member>Update shift details and preferred coverers.</p>
          </div>
          <button class="rounded-lg border border-slate-300 px-3 py-2 text-sm hover:bg-slate-50" type="button" data-close-shift-dialog>Cancel</button>
        </div>

        <div class="mt-5 grid gap-4 sm:grid-cols-6">
          <label class="block sm:col-span-2">
            <div class="text-sm font-medium text-slate-800">Area</div>
            <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="homeAreaKey" required>
              {areas.map((a) => (
                <option value={a.key}>{a.label}</option>
              ))}
            </select>
          </label>

          <label class="block">
            <div class="text-sm font-medium text-slate-800">Status</div>
            <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="statusKey" required>
              {statuses.map((st) => (
                <option value={st.key}>{st.label}</option>
              ))}
            </select>
          </label>

          <label class="block">
            <div class="text-sm font-medium text-slate-800">Role</div>
            <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="shiftRole">
              <option value="normal">Normal</option>
              <option value="floater">Floater</option>
            </select>
          </label>

          <label class="block">
            <div class="text-sm font-medium text-slate-800">Start</div>
            <input class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" type="time" name="startTime" required step="60" />
          </label>

          <label class="block">
            <div class="text-sm font-medium text-slate-800">End</div>
            <input class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" type="time" name="endTime" required step="60" data-bunrun-endtime />
          </label>
        </div>

        <div class="mt-5">
          <div class="text-sm font-medium text-slate-800">Preferred coverers</div>
          <div class="mt-2 grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
            {Array.from({ length: 4 }, (_, index) => (
              <label class="block">
                <div class="text-xs text-slate-500">Priority {index + 1}</div>
                <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="preferredCovererIds">
                  <option value="">— none —</option>
                  {members.map((member) => (
                    <option value={member.id}>{member.name}</option>
                  ))}
                </select>
              </label>
            ))}
          </div>
          <div class="mt-1 text-xs text-slate-500">The planner tries these members first, in order, when they are valid for the break.</div>
        </div>

        <div class="mt-4 text-sm text-slate-600">
          Note: setting status to <b>Sick</b> removes their breaks and clears any cover assignments where they were covering others.
        </div>
        <div data-shiftWarn class="mt-3 text-sm"></div>

        <div class="mt-6 flex justify-end gap-3">
          <button class="rounded-lg border border-slate-300 bg-white px-4 py-2 hover:bg-slate-50" type="button" data-close-shift-dialog>Cancel</button>
          <button class="rounded-lg bg-slate-900 px-4 py-2 font-medium text-white hover:bg-slate-800" type="submit">Save</button>
        </div>
      </form>
    </dialog>

    <div class="mt-8 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <Runsheet date={date} areas={areas} shifts={shifts} breaks={breaks} />
    </div>

    <div class="mt-8 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <h2 class="text-lg font-medium">Break timeline</h2>
          <p class="mt-2 text-sm text-slate-600">Breaks in chronological order, including who is covering each break.</p>
        </div>
        <div class="text-sm text-slate-500">{chronologicalBreakRows.length} break{chronologicalBreakRows.length === 1 ? '' : 's'}</div>
      </div>

      {chronologicalBreakRows.length > 0 ? (
        <div class="mt-4 overflow-x-auto">
          <table class="w-full min-w-[760px] border-separate border-spacing-y-2 text-sm">
            <thead>
              <tr class="text-left text-slate-600">
                <th class="px-3">Time</th>
                <th class="px-3">Member</th>
                <th class="px-3">Area</th>
                <th class="px-3">Duration</th>
                <th class="px-3">Cover</th>
              </tr>
            </thead>
            <tbody>
              {chronologicalBreakRows.map((row) => (
                <tr class:list={['bg-slate-50', !row.cover_member_name && 'bg-rose-50']}>
                  <td class="px-3 py-3 font-medium">{row.start_time}</td>
                  <td class="px-3 py-3">{row.off_member_name}</td>
                  <td class="px-3 py-3">{row.off_area_label}</td>
                  <td class="px-3 py-3">{row.duration_minutes}m</td>
                  <td class="px-3 py-3">
                    {row.cover_member_name ? (
                      <div class="flex flex-wrap items-center gap-2">
                        <span>{row.cover_member_name}</span>
                        {row.cover_shift_role === 'floater' && (
                          <span class="rounded-full bg-sky-100 px-2 py-0.5 text-xs font-semibold text-sky-900">Floater</span>
                        )}
                      </div>
                    ) : (
                      <span class="font-medium text-rose-700">Missing cover</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="mt-4 text-sm text-slate-600">No breaks planned yet.</div>
      )}
    </div>

    <div id="breaks" class="mt-8 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <h2 class="text-lg font-medium">Break planning</h2>
          <p class="mt-2 text-sm text-slate-600">
            {showBreakPlanning ? 'Add breaks and assign cover.' : 'Open the break planning workspace when you need to assign cover or edit breaks.'}
          </p>
        </div>
        {showBreakPlanning ? (
          <a class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm hover:bg-slate-50" href={`/admin/schedule/${date}`}>
            Close break planning
          </a>
        ) : (
          <a class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800" href={breakPanelUrl}>
            Open break planning
          </a>
        )}
      </div>

      {!showBreakPlanning && (
        <div class="mt-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">Working shifts</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900">{workingShifts.length}</div>
          </div>
          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">Breaks planned</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900">{breaks.length}</div>
          </div>
          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">Missing cover</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900">{uncoveredBreaks.length}</div>
          </div>
        </div>
      )}

      {showBreakPlanning && (
        <>
          {breakPlanningBlocks.length === 0 && (
            <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
              No continuous working blocks are currently available for break planning on this day. If this looks wrong, the roster may need its work blocks recomputed.
            </div>
          )}
          <div class="mt-4 flex flex-wrap gap-2">
            <form method="post" action="/api/breaks/autogen-all">
              <input type="hidden" name="date" value={date} />
              <input type="hidden" name="mode" value="overwrite" />
              <input type="hidden" name="returnTo" value={breakPanelUrl} />
              <button class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800" type="submit">
                Auto-generate ALL (overwrite)
              </button>
            </form>

            <form method="post" action="/api/breaks/autogen-all">
              <input type="hidden" name="date" value={date} />
              <input type="hidden" name="mode" value="missing" />
              <input type="hidden" name="returnTo" value={breakPanelUrl} />
              <button class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm hover:bg-slate-50" type="submit">
                Auto-generate missing only
              </button>
            </form>

            <form method="post" action="/api/breaks/revalidate">
              <input type="hidden" name="date" value={date} />
              <input type="hidden" name="returnTo" value={breakPanelUrl} />
              <button class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm hover:bg-slate-50" type="submit">
                Revalidate
              </button>
            </form>

            <form method="post" action="/api/breaks/autofix">
              <input type="hidden" name="date" value={date} />
              <input type="hidden" name="returnTo" value={breakPanelUrl} />
              <button class="rounded-lg bg-emerald-700 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-800" type="submit">
                Auto-fix covers
              </button>
            </form>
          </div>
          <div class="mt-6 space-y-8">
            {breakPlanningBlocks.map((block) => {
              const rows = breaksByWorkBlock.get(block.id) ?? [];
              const used = plannedBreakMinutesByWorkBlock.get(block.id) ?? 0;
              const allowance = breakAllowanceMinutes(block.total_minutes);
              const shiftSummary = block.shifts.map((shift) => `${shift.area_label} ${shift.start_time}-${shift.end_time ?? '—'}`).join(' · ');

              return (
                <section class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <div>
                      <div class="font-semibold">{block.member_name}</div>
                      <div class="text-sm text-slate-600">
                        {block.start_time}–{block.end_time} · block {formatDurationMinutes(block.total_minutes)} · allowance {allowance}m · planned {used}m
                      </div>
                      <div class="mt-1 text-xs text-slate-500">{shiftSummary}</div>
                    </div>
                    <form method="post" action="/api/breaks/autogen">
                      <input type="hidden" name="date" value={date} />
                      <input type="hidden" name="workBlockId" value={block.id} />
                      <input type="hidden" name="returnTo" value={breakPanelUrl} />
                      <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" type="submit">
                        Auto-generate
                      </button>
                    </form>
                  </div>

                  <div class="mt-4 overflow-x-auto">
                    <table class="w-full min-w-[860px] border-separate border-spacing-y-2 text-sm">
                      <thead>
                        <tr class="text-left text-slate-600">
                          <th class="px-3">Start</th>
                          <th class="px-3">Area at break</th>
                          <th class="px-3">Duration</th>
                          <th class="px-3">Cover</th>
                          <th class="px-3"></th>
                        </tr>
                      </thead>
                      <tbody>
                        {rows.map((b) => {
                          const activeShift = shiftViewById.get(b.shift_id);
                          return (
                            <tr
                              class={
                                b.cover_member_id == null
                                  ? 'bg-rose-50'
                                  : invalidReasonByBreakId.has(b.id)
                                    ? 'bg-amber-50'
                                    : 'bg-white'
                              }
                            >
                              <td class="px-3 py-3">
                                {b.start_time}
                                {invalidReasonByBreakId.has(b.id) && (
                                  <div class="mt-1 text-xs text-amber-900">{invalidReasonByBreakId.get(b.id)}</div>
                                )}
                              </td>
                              <td class="px-3 py-3">{activeShift?.area_label ?? '—'}</td>
                              <td class="px-3 py-3">{b.duration_minutes}m</td>
                              <td class="px-3 py-3">
                                <form method="post" action="/api/breaks/assign-cover" class="flex items-center gap-2">
                                  <input type="hidden" name="date" value={date} />
                                  <input type="hidden" name="breakId" value={b.id} />
                                  <input type="hidden" name="returnTo" value={breakPanelUrl} />
                                  <select class="rounded-lg border border-slate-300 bg-white px-2 py-2" name="coverMemberId">
                                    <option value="" selected={b.cover_member_id == null}>— missing cover —</option>
                                    {(coverCandidatesByBreakId.get(b.id) ?? []).map((cs) => (
                                      <option value={cs.id} selected={b.cover_member_id === cs.id}>
                                        {cs.name}
                                      </option>
                                    ))}
                                  </select>
                                  <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 hover:bg-slate-50" type="submit">
                                    Set
                                  </button>
                                </form>
                              </td>
                              <td class="px-3 py-3">
                                <form method="post" action="/api/breaks/delete" onsubmit="return confirm('Delete this break?')">
                                  <input type="hidden" name="date" value={date} />
                                  <input type="hidden" name="breakId" value={b.id} />
                                  <input type="hidden" name="returnTo" value={breakPanelUrl} />
                                  <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 hover:bg-slate-50" type="submit">
                                    Delete
                                  </button>
                                </form>
                              </td>
                            </tr>
                          );
                        })}

                        <tr class="bg-white">
                          <td class="px-3 py-3" colspan="5">
                            <form method="post" action="/api/breaks/add" class="flex flex-wrap items-center gap-2">
                              <input type="hidden" name="date" value={date} />
                              <input type="hidden" name="workBlockId" value={block.id} />
                              <input type="hidden" name="returnTo" value={breakPanelUrl} />

                              <div class="mr-2 text-sm font-medium text-slate-700">Add break</div>

                              <input class="w-16 rounded-lg border border-slate-300 bg-white px-2 py-2" type="number" name="hh" min="0" max="23" placeholder="10" required />
                              <span class="text-slate-600">:</span>
                              <input class="w-16 rounded-lg border border-slate-300 bg-white px-2 py-2" type="number" name="mm" min="0" max="59" value="00" required />

                              <select class="rounded-lg border border-slate-300 bg-white px-2 py-2" name="duration">
                                {[15, 30, 45, 60].map((d) => (
                                  <option value={d}>{d}m</option>
                                ))}
                              </select>

                              <button class="rounded-lg bg-emerald-700 px-3 py-2 font-medium text-white hover:bg-emerald-800" type="submit">
                                Add
                              </button>
                            </form>
                          </td>
                        </tr>
                      </tbody>
                    </table>
                  </div>

                  {used > allowance && (
                    <div class="mt-3 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-900">
                      Planned break time exceeds allowance for this continuous work block.
                    </div>
                  )}
                </section>
              );
            })}
          </div>
        </>
      )}
    </div>
  </div>
  <script is:inline>
    const shiftDialogs = {
      add: document.querySelector('[data-shift-dialog="add"]'),
      edit: document.querySelector('[data-shift-dialog="edit"]')
    };

    const showShiftDialog = (dialog) => dialog && typeof dialog.showModal === 'function' && dialog.showModal();
    const closeShiftDialog = (dialog) => dialog && typeof dialog.close === 'function' && dialog.close();

    document.querySelector('[data-open-add-shift]')?.addEventListener('click', () => showShiftDialog(shiftDialogs.add));

    document.querySelectorAll('[data-close-shift-dialog]').forEach((button) => {
      button.addEventListener('click', () => closeShiftDialog(button.closest('dialog')));
    });

    document.querySelectorAll('[data-open-edit-shift]').forEach((button) => {
      button.addEventListener('click', () => {
        const dialog = shiftDialogs.edit;
        if (!dialog) return;
        const form = dialog.querySelector('form');
        if (!form) return;
        const memberId = button.dataset.memberId || '';

        form.querySelector('input[name="shiftId"]').value = button.dataset.shiftId || '';
        form.querySelector('select[name="homeAreaKey"]').value = button.dataset.homeAreaKey || '';
        form.querySelector('select[name="statusKey"]').value = button.dataset.statusKey || 'working';
        form.querySelector('select[name="shiftRole"]').value = button.dataset.shiftRole || 'normal';
        form.querySelector('input[name="startTime"]').value = button.dataset.startTime || '';
        form.querySelector('input[name="endTime"]').value = button.dataset.endTime || '';
        dialog.querySelector('[data-edit-shift-member]').textContent = `Update ${button.dataset.memberName || 'this member'}'s shift details and preferred coverers.`;

        const preferred = (button.dataset.preferredCoverers || '').split(',').filter(Boolean);
        form.querySelectorAll('select[name="preferredCovererIds"]').forEach((select, index) => {
          Array.from(select.options).forEach((option) => {
            option.disabled = Boolean(memberId) && option.value === memberId;
          });
          select.value = preferred[index] || '';
        });

        showShiftDialog(dialog);
      });
    });
  </script>
</Layout>
