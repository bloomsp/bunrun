---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { requireRole } from '../../../lib/auth';
import { getDB } from '../../../lib/db';
import { formatDurationMinutes, operatingHoursFor, parseHHMM } from '../../../lib/time';
import { breakAllowanceMinutes } from '../../../lib/breaks';
import { addDays, formatLongDateLabel, formatShortDateLabel, startOfWeek, weekDatesFor } from '../../../lib/schedule';
import { countWorkingShiftsByAreaInRange, firstActiveShiftInRange } from '../../../lib/shifts';
import Runsheet from '../../../components/Runsheet.astro';

const guard = requireRole(Astro.request, 'admin');
if (!guard.ok) return guard.redirect;

const date = Astro.params.date ?? '';
if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) {
  return new Response('Invalid date', { status: 400 });
}

type Member = {
  id: number;
  name: string;
  active: number;
  all_areas: number;
  default_area_key: string | null;
};

type Area = { key: string; label: string; min_staff?: number };

type ShiftRow = {
  id: number;
  member_id: number;
  name: string;
  home_area_key: string;
  status_key: string;
  start_time: string;
  end_time: string | null;
  shift_minutes: number;
};

type BreakRow = {
  id: number;
  shift_id: number;
  start_time: string;
  duration_minutes: number;
  cover_member_id: number | null;
};

type Status = { key: string; label: string; blocks_coverage: number };

type WeekSummary = {
  date: string;
  shift_count: number;
  working_count: number;
};

type ShiftView = ShiftRow & {
  start_minutes: number;
  end_minutes: number | null;
  computed_minutes: number;
  warnings: string[];
  status_label: string;
  area_label: string;
};

const breakPanelUrl = `/admin/schedule/${date}?panel=breaks#breaks`;
const showBreakPlanning = Astro.url.searchParams.get('panel') === 'breaks';

const DB = await getDB();

// Ensure schedule exists
await DB.prepare('INSERT OR IGNORE INTO schedules (date) VALUES (?)').bind(date).run();
const schedule = (await DB.prepare('SELECT id, date FROM schedules WHERE date=?').bind(date).first()) as any;
const scheduleId = schedule.id as number;

const shifts = (await DB.prepare(
  `SELECT s.id, s.member_id, m.name, s.home_area_key, s.status_key, s.start_time, s.end_time, s.shift_minutes
   FROM shifts s
   JOIN members m ON m.id = s.member_id
   WHERE s.schedule_id=?
   ORDER BY s.home_area_key ASC, m.name COLLATE NOCASE ASC`
).bind(scheduleId).all()).results as ShiftRow[];

const breaks = (await DB.prepare(
  `SELECT b.id, b.shift_id, b.start_time, b.duration_minutes, b.cover_member_id
   FROM breaks b
   JOIN shifts s ON s.id = b.shift_id
   WHERE s.schedule_id=?
   ORDER BY b.start_time ASC`
).bind(scheduleId).all()).results as BreakRow[];

const breaksByShift = new Map<number, BreakRow[]>();
for (const b of breaks) {
  const arr = breaksByShift.get(b.shift_id) ?? [];
  arr.push(b);
  breaksByShift.set(b.shift_id, arr);
}

const members = (await DB.prepare(
  'SELECT id, name, active, all_areas, default_area_key FROM members WHERE active=1 ORDER BY name COLLATE NOCASE ASC'
).all()).results as Member[];

const areas = (await DB.prepare('SELECT key, label, min_staff FROM areas ORDER BY label COLLATE NOCASE ASC').all()).results as Area[];

const statuses = (await DB.prepare('SELECT key, label, blocks_coverage FROM statuses ORDER BY label COLLATE NOCASE ASC').all())
  .results as Status[];

const perms = (await DB.prepare('SELECT member_id, area_key FROM member_area_permissions').all()).results as any[];
const permsByMember = new Map<number, Set<string>>();
for (const p of perms) {
  const set = permsByMember.get(p.member_id) ?? new Set<string>();
  set.add(p.area_key);
  permsByMember.set(p.member_id, set);
}

const memberById = new Map(members.map((m) => [m.id, m]));
const areaByKey = new Map(areas.map((a) => [a.key, a]));
const statusByKey = new Map(statuses.map((s) => [s.key, s]));
const shiftById = new Map(shifts.map((s) => [s.id, s]));
const op = operatingHoursFor(date);
const shiftsByMember = new Map<number, ShiftRow[]>();
for (const shift of shifts) {
  const arr = shiftsByMember.get(shift.member_id) ?? [];
  arr.push(shift);
  shiftsByMember.set(shift.member_id, arr);
}

const areaMinByKey = new Map(areas.map((a: any) => [a.key, Number((a as any).min_staff ?? 0)]));
const workingShifts = shifts.filter((s) => s.status_key === 'working');
const workingShiftIds = new Set(workingShifts.map((s) => s.id));
const uncoveredBreaks = breaks.filter((b) => workingShiftIds.has(b.shift_id) && b.cover_member_id == null);

// base working counts per area
const shiftViews = shifts.map((s) => {
  const startMinutes = parseHHMM(s.start_time) ?? 0;
  const endMinutes = s.end_time ? parseHHMM(s.end_time) : null;
  const computedMinutes = endMinutes != null ? endMinutes - startMinutes : s.shift_minutes;
  return {
    ...s,
    start_minutes: startMinutes,
    end_minutes: endMinutes,
    computed_minutes: computedMinutes,
    warnings: endMinutes != null ? warningsForShift(s.start_time, s.end_time!, computedMinutes) : [],
    status_label: statusByKey.get(s.status_key)?.label ?? s.status_key,
    area_label: areaByKey.get(s.home_area_key)?.label ?? s.home_area_key
  } satisfies ShiftView;
});
const shiftViewById = new Map(shiftViews.map((s) => [s.id, s]));
const shiftViewsByArea = new Map<string, ShiftView[]>();
const workingShiftViewsByArea = new Map<string, ShiftView[]>();
for (const shift of shiftViews) {
  const allAreaShifts = shiftViewsByArea.get(shift.home_area_key) ?? [];
  allAreaShifts.push(shift);
  shiftViewsByArea.set(shift.home_area_key, allAreaShifts);

  if (shift.status_key === 'working') {
    const workingAreaShifts = workingShiftViewsByArea.get(shift.home_area_key) ?? [];
    workingAreaShifts.push(shift);
    workingShiftViewsByArea.set(shift.home_area_key, workingAreaShifts);
  }
}
const breakRangeById = new Map<number, { start: number; end: number }>();
for (const b of breaks) {
  const parsed = rangeFor(b.start_time, b.duration_minutes);
  if (parsed) breakRangeById.set(b.id, parsed);
}
const coveredBreaksByMember = new Map<number, BreakRow[]>();
const breaksByOffMember = new Map<number, BreakRow[]>();
for (const b of breaks) {
  if (b.cover_member_id == null) continue;
  const arr = coveredBreaksByMember.get(b.cover_member_id) ?? [];
  arr.push(b);
  coveredBreaksByMember.set(b.cover_member_id, arr);
}
for (const b of breaks) {
  const offShift = shiftById.get(b.shift_id);
  if (!offShift) continue;
  const arr = breaksByOffMember.get(offShift.member_id) ?? [];
  arr.push(b);
  breaksByOffMember.set(offShift.member_id, arr);
}
const plannedBreakMinutesByShift = new Map<number, number>();
for (const [shiftId, rows] of breaksByShift.entries()) {
  plannedBreakMinutesByShift.set(
    shiftId,
    rows.reduce((sum, row) => sum + row.duration_minutes, 0)
  );
}

function canCoverArea(memberId: number, areaKey: string) {
  const m = memberById.get(memberId);
  if (!m) return false;
  // @ts-expect-error optional from DB
  if ((m as any).all_areas === 1) return true;
  const set = permsByMember.get(memberId);
  return Boolean(set?.has(areaKey));
}

function coverOverlaps(memberId: number, target: { start: number; end: number }, breakId: number) {
  for (const b of coveredBreaksByMember.get(memberId) ?? []) {
    if (b.id === breakId) continue;
    const r = breakRangeById.get(b.id);
    if (r && overlap(target.start, target.end, r.start, r.end)) return true;
  }

  for (const b of breaksByOffMember.get(memberId) ?? []) {
    if (b.id === breakId) continue;
    const r = breakRangeById.get(b.id);
    if (r && overlap(target.start, target.end, r.start, r.end)) return true;
  }
  return false;
}

function activeShiftForMember(memberId: number, target: { start: number; end: number }, opts?: { workingOnly?: boolean }) {
  return firstActiveShiftInRange(shiftsByMember.get(memberId) ?? [], target, { workingOnly: opts?.workingOnly });
}

function violatesMins(offAreaKey: string, coverMemberId: number, target: { start: number; end: number }) {
  const coverShift = activeShiftForMember(coverMemberId, target, { workingOnly: true });
  if (!coverShift) return true;
  const counts = countWorkingShiftsByAreaInRange(shifts, target);
  counts.set(offAreaKey, (counts.get(offAreaKey) ?? 0) - 1);
  if (coverShift.home_area_key !== offAreaKey) {
    counts.set(coverShift.home_area_key, (counts.get(coverShift.home_area_key) ?? 0) - 1);
    counts.set(offAreaKey, (counts.get(offAreaKey) ?? 0) + 1);
  }
  for (const [k, min] of areaMinByKey.entries()) {
    if ((counts.get(k) ?? 0) < min) return true;
  }
  return false;
}

const invalidCoverBreaks: { id: number; reason: string }[] = [];
if (showBreakPlanning) {
  for (const b of breaks) {
    if (!workingShiftIds.has(b.shift_id)) continue;
    if (b.cover_member_id == null) continue;

    const coverId = b.cover_member_id;
    const target = breakRangeById.get(b.id);
    const coverShift = target ? activeShiftForMember(coverId, target, { workingOnly: true }) : null;
    if (!coverShift) {
      invalidCoverBreaks.push({ id: b.id, reason: 'Cover not on roster' });
      continue;
    }

    const offShift = shiftById.get(b.shift_id);
    const offAreaKey = offShift?.home_area_key;
    if (!offAreaKey) continue;

    if (!canCoverArea(coverId, offAreaKey)) {
      invalidCoverBreaks.push({ id: b.id, reason: 'Cover not permitted for area' });
      continue;
    }

    if (target && coverOverlaps(coverId, target, b.id)) {
      invalidCoverBreaks.push({ id: b.id, reason: 'Cover conflict (overlap)' });
      continue;
    }

    if (target && violatesMins(offAreaKey, coverId, target)) {
      invalidCoverBreaks.push({ id: b.id, reason: 'Area minimum violated' });
      continue;
    }
  }
}

const invalidReasonByBreakId = new Map(invalidCoverBreaks.map((x) => [x.id, x.reason]));

const editShiftId = Number(Astro.url.searchParams.get('editShift') || '0');
const notice = Astro.url.searchParams.get('notice');
const errorMsg = Astro.url.searchParams.get('error');
const weekStart = startOfWeek(date);
const weekDates = weekDatesFor(date);
const previousWeekDate = addDays(weekStart, -7);
const nextWeekDate = addDays(weekStart, 7);
const weekEnd = weekDates[6] ?? date;
const weekSummaryRows = (
  await DB.prepare(
    `SELECT sc.date,
            COUNT(sh.id) AS shift_count,
            SUM(CASE WHEN sh.status_key='working' THEN 1 ELSE 0 END) AS working_count
     FROM schedules sc
     LEFT JOIN shifts sh ON sh.schedule_id = sc.id
     WHERE sc.date >= ? AND sc.date <= ?
     GROUP BY sc.date`
  )
    .bind(weekStart, weekEnd)
    .all()
).results as WeekSummary[];
const weekSummaryByDate = new Map(
  weekSummaryRows.map((row) => [
    row.date,
    {
      shiftCount: Number(row.shift_count ?? 0),
      workingCount: Number(row.working_count ?? 0)
    }
  ])
);

function warningsForShift(start: string, end: string, minutes: number): string[] {
  const out: string[] = [];
  if (minutes > 9 * 60) out.push('Long shift (> 9h)');
  if (minutes > 10 * 60) out.push('Shift exceeds 10h max');
  if (op) {
    const s = parseHHMM(start);
    const e = parseHHMM(end);
    if (s != null && e != null) {
      if (s < op.open || e > op.close) out.push('Outside operating hours');
    }
  }
  return out;
}

function canWorkArea(memberId: number, areaKey: string) {
  const m = memberById.get(memberId);
  if (!m) return false;
  if (m.all_areas === 1) return true;
  const set = permsByMember.get(memberId);
  return Boolean(set?.has(areaKey));
}

function overlap(aStart: number, aEnd: number, bStart: number, bEnd: number) {
  return aStart < bEnd && bStart < aEnd;
}

function rangeFor(start: string, duration: number) {
  const s = parseHHMM(start);
  if (s == null) return null;
  return { start: s, end: s + duration };
}

function coverCandidatesForBreak(offShift: ShiftView, targetBreak: BreakRow) {
  const target = breakRangeById.get(targetBreak.id);
  return workingShifts.filter((candidate) => {
    if (candidate.member_id === offShift.member_id) return false;
    if (!target) return false;
    if (candidate.id !== activeShiftForMember(candidate.member_id, target, { workingOnly: true })?.id) return false;
    if (!canWorkArea(candidate.member_id, offShift.home_area_key)) return false;

    for (const ownBreak of breaksByShift.get(candidate.id) ?? []) {
      const ownRange = breakRangeById.get(ownBreak.id);
      if (ownRange && overlap(target.start, target.end, ownRange.start, ownRange.end)) return false;
    }

    for (const coveredBreak of coveredBreaksByMember.get(candidate.member_id) ?? []) {
      if (coveredBreak.id === targetBreak.id) continue;
      const coveredRange = breakRangeById.get(coveredBreak.id);
      if (coveredRange && overlap(target.start, target.end, coveredRange.start, coveredRange.end)) return false;
    }

    return true;
  });
}

const coverCandidatesByBreakId = new Map<number, ShiftRow[]>();
if (showBreakPlanning) {
  for (const shift of workingShifts) {
    for (const b of breaksByShift.get(shift.id) ?? []) {
      coverCandidatesByBreakId.set(b.id, coverCandidatesForBreak(shiftViewById.get(shift.id) ?? (shift as ShiftView), b));
    }
  }
}
---

<Layout title={`Schedule ${date} | Bunrun`}>
  <script src="/js/schedule-time.js?v=4" defer></script>
  <div class="mx-auto max-w-5xl px-4 py-10">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight">Schedule</h1>
        <div class="mt-1 text-slate-700">{formatLongDateLabel(date)}</div>
        <div class="mt-1 text-sm text-slate-500">Week of {weekStart}</div>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href={`/admin/schedule/${previousWeekDate}`}>
          Previous week
        </a>
        <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href={`/admin/schedule/${nextWeekDate}`}>
          Next week
        </a>
        <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href="/admin/schedule">Change date</a>
        <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href="/admin">Admin</a>
      </div>
    </div>

    <div class="mt-6 overflow-x-auto">
      <div class="flex min-w-max gap-3">
        {weekDates.map((tabDate) => {
          const summary = weekSummaryByDate.get(tabDate) ?? { shiftCount: 0, workingCount: 0 };
          const active = tabDate === date;
          return (
            <a
              class:list={[
                'min-w-[132px] rounded-2xl border px-4 py-3 text-left transition',
                active
                  ? 'border-emerald-600 bg-emerald-50 text-emerald-950 shadow-sm'
                  : 'border-slate-200 bg-white text-slate-800 hover:border-slate-300 hover:bg-slate-50'
              ]}
              href={`/admin/schedule/${tabDate}`}
            >
              <div class="text-sm font-semibold">{formatShortDateLabel(tabDate)}</div>
              <div class="mt-1 text-xs text-slate-600">
                {summary.shiftCount} shift{summary.shiftCount === 1 ? '' : 's'}
              </div>
              <div class="mt-0.5 text-xs text-slate-500">
                {summary.workingCount} working
              </div>
            </a>
          );
        })}
      </div>
    </div>

    {op && (
      <div class="mt-3 text-sm text-slate-600">
        Operating hours: {Math.floor(op.open / 60).toString().padStart(2, '0')}:{String(op.open % 60).padStart(2, '0')}
        – {Math.floor(op.close / 60).toString().padStart(2, '0')}:{String(op.close % 60).padStart(2, '0')}
      </div>
    )}

    {errorMsg && (
      <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 p-4 text-rose-900">
        <div class="font-semibold">Action blocked</div>
        <div class="mt-1 text-sm">{errorMsg}</div>
      </div>
    )}

    {notice && (
      <div class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900">
        <div class="font-semibold">Updated</div>
        <div class="mt-1 text-sm">{notice}</div>
      </div>
    )}

    {(uncoveredBreaks.length > 0 || invalidCoverBreaks.length > 0) && (
      <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 p-4 text-rose-900">
        <div class="font-semibold">Schedule needs attention</div>
        <div class="mt-1 text-sm">
          {uncoveredBreaks.length > 0 && (
            <span>
              {uncoveredBreaks.length} break{uncoveredBreaks.length === 1 ? '' : 's'} {uncoveredBreaks.length === 1 ? 'is' : 'are'} missing cover.
            </span>
          )}
          {invalidCoverBreaks.length > 0 && (
            <span class="ml-2">
              {invalidCoverBreaks.length} break{invalidCoverBreaks.length === 1 ? '' : 's'} {invalidCoverBreaks.length === 1 ? 'has' : 'have'} invalid cover.
            </span>
          )}
          <a class="ml-2 underline" href={breakPanelUrl}>Review break planning</a>
        </div>
      </div>
    )}

    <div class="mt-8 grid gap-4 xl:grid-cols-2">
      <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-medium">Copy day</h2>
        <p class="mt-2 text-sm text-slate-600">Replace this day's shifts and breaks with another date.</p>
        <form class="mt-4 flex flex-wrap items-end gap-3" method="post" action="/api/schedule/copy-day" onsubmit={`return confirm('Copy the selected day into ${date}? This overwrites the current day.')`}>
          <input type="hidden" name="targetDate" value={date} />
          <label class="block">
            <div class="text-sm font-medium text-slate-800">Source day</div>
            <input class="mt-1 rounded-lg border border-slate-300 bg-white px-3 py-2" type="date" name="sourceDate" value={addDays(date, -7)} required />
          </label>
          <button class="rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800" type="submit">
            Copy into {date}
          </button>
        </form>
      </section>

      <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-medium">Copy week</h2>
        <p class="mt-2 text-sm text-slate-600">Replace every day in this week with the matching day from another week.</p>
        <form class="mt-4 flex flex-wrap items-end gap-3" method="post" action="/api/schedule/copy-week" onsubmit={`return confirm('Copy the selected week into the week of ${weekStart}? This overwrites all 7 days.')`}>
          <input type="hidden" name="targetWeekDate" value={weekStart} />
          <label class="block">
            <div class="text-sm font-medium text-slate-800">Source week</div>
            <input class="mt-1 rounded-lg border border-slate-300 bg-white px-3 py-2" type="date" name="sourceWeekDate" value={addDays(weekStart, -7)} required />
          </label>
          <button class="rounded-lg bg-emerald-700 px-4 py-2.5 text-sm font-medium text-white hover:bg-emerald-800" type="submit">
            Copy into week of {weekStart}
          </button>
        </form>
      </section>
    </div>

    <div class="mt-8 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-medium">Add shift</h2>
      <form class="mt-4 grid gap-3 sm:grid-cols-6" method="post" action="/api/shifts/upsert">
        <input type="hidden" name="date" value={date} />

        <label class="block sm:col-span-2">
          <div class="text-sm font-medium text-slate-800">Member</div>
          <select
            class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
            name="memberId"
            required
            data-bunrun-member
          >
            <option value="" selected>Select…</option>
            {members.map((m) => (
                <option value={m.id} data-default-area={m.default_area_key ?? ''}>
                  {m.name}
                </option>
              ))}
          </select>
        </label>

        <label class="block">
          <div class="text-sm font-medium text-slate-800">Area</div>
          <select
            class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
            name="homeAreaKey"
            required
            data-bunrun-area
          >
            {areas.map((a) => (
              <option value={a.key}>{a.label}</option>
            ))}
          </select>
        </label>

        <label class="block">
          <div class="text-sm font-medium text-slate-800">Status</div>
          <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="statusKey" required>
            {statuses.map((s) => (
              <option value={s.key} selected={s.key === 'working'}>{s.label}</option>
            ))}
          </select>
        </label>

        <label class="block">
          <div class="text-sm font-medium text-slate-800">Start</div>
          <input
            class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
            type="time"
            name="startTime"
            value="06:00"
            required
            step="60"
          />
        </label>

        <label class="block">
          <div class="text-sm font-medium text-slate-800">End</div>
          <input
            class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2"
            type="time"
            name="endTime"
            value="15:00"
            required
            step="60"
            data-bunrun-endtime
          />
        </label>

        <div class="sm:col-span-6">
          <button
            class="rounded-lg bg-emerald-700 px-4 py-2.5 font-medium text-white hover:bg-emerald-800"
            type="submit"
            data-bunrun-add-shift
          >
            Add shift
          </button>
        </div>
      </form>
    </div>

    <div class="mt-8 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-medium">Shifts</h2>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full min-w-[900px] border-separate border-spacing-y-2 text-sm">
          <thead>
            <tr class="text-left text-slate-600">
              <th class="px-3">Member</th>
              <th class="px-3">Area</th>
              <th class="px-3">Status</th>
              <th class="px-3">Start</th>
              <th class="px-3">End</th>
              <th class="px-3">Length</th>
              <th class="px-3">Warnings</th>
              <th class="px-3"></th>
            </tr>
          </thead>
          <tbody>
            {shiftViews.map((s) => {
              const isEditing = editShiftId === s.id;

              if (isEditing) {
                return (
                  <tr class="bg-slate-50">
                    <td class="px-3 py-3 font-medium">{s.name}</td>
                    <td class="px-3 py-3" colspan="7">
                      <form class="grid gap-3 sm:grid-cols-6" method="post" action="/api/shifts/update">
                        <input type="hidden" name="date" value={date} />
                        <input type="hidden" name="shiftId" value={s.id} />

                        <label class="block sm:col-span-2">
                          <div class="text-xs font-medium text-slate-700">Area</div>
                          <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="homeAreaKey" required>
                            {areas.map((a) => (
                              <option value={a.key} selected={a.key === s.home_area_key}>{a.label}</option>
                            ))}
                          </select>
                        </label>

                        <label class="block">
                          <div class="text-xs font-medium text-slate-700">Status</div>
                          <select class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" name="statusKey" required>
                            {statuses.map((st) => (
                              <option value={st.key} selected={st.key === s.status_key}>{st.label}</option>
                            ))}
                          </select>
                        </label>

                        <label class="block">
                          <div class="text-xs font-medium text-slate-700">Start</div>
                          <input class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" type="time" name="startTime" value={s.start_time} required step="60" />
                        </label>

                        <label class="block">
                          <div class="text-xs font-medium text-slate-700">End</div>
                          <input class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2" type="time" name="endTime" value={s.end_time ?? ''} required step="60" />
                        </label>

                        <div class="sm:col-span-1 flex items-end gap-2">
                          <button class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800" type="submit">
                            Save
                          </button>
                          <a class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm hover:bg-slate-50" href={`/admin/schedule/${date}`}>
                            Cancel
                          </a>
                        </div>
                      </form>
                      <div class="mt-2 text-xs text-slate-600">
                        Note: setting status to <b>Sick</b> removes their breaks and clears any cover assignments where they were covering others.
                      </div>
                    </td>
                  </tr>
                );
              }

              return (
                <tr class="bg-slate-50">
                  <td class="px-3 py-3 font-medium">{s.name}</td>
                  <td class="px-3 py-3">{s.area_label}</td>
                  <td class="px-3 py-3">
                    {s.status_key === 'sick' ? (
                      <span class="rounded bg-rose-100 px-2 py-1 font-medium text-rose-900">Sick</span>
                    ) : (
                      s.status_label
                    )}
                  </td>
                  <td class="px-3 py-3">{s.start_time}</td>
                  <td class="px-3 py-3">{s.end_time ?? '—'}</td>
                  <td class="px-3 py-3">{formatDurationMinutes(s.computed_minutes)}</td>
                  <td class="px-3 py-3">
                    {s.warnings.length ? (
                      <span class="rounded bg-amber-100 px-2 py-1 text-amber-900">{s.warnings.join(' · ')}</span>
                    ) : (
                      <span class="text-slate-500">—</span>
                    )}
                  </td>
                  <td class="px-3 py-3">
                    <div class="flex items-center gap-2">
                      <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 hover:bg-slate-100" href={`/admin/schedule/${date}?editShift=${s.id}`}>
                        Edit
                      </a>
                      <form method="post" action="/api/shifts/delete" onsubmit="return confirm('Delete this shift?')">
                        <input type="hidden" name="shiftId" value={s.id} />
                        <input type="hidden" name="date" value={date} />
                        <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 hover:bg-slate-100" type="submit">
                          Delete
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      {shifts.length === 0 && <div class="mt-4 text-sm text-slate-600">No shifts yet.</div>}
    </div>

    <div class="mt-8 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <Runsheet date={date} areas={areas} shifts={shifts} breaks={breaks} />
    </div>

    <div id="breaks" class="mt-8 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <h2 class="text-lg font-medium">Break planning</h2>
          <p class="mt-2 text-sm text-slate-600">
            {showBreakPlanning ? 'Add breaks and assign cover.' : 'Open the break planning workspace when you need to assign cover or edit breaks.'}
          </p>
        </div>
        {showBreakPlanning ? (
          <a class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm hover:bg-slate-50" href={`/admin/schedule/${date}`}>
            Close break planning
          </a>
        ) : (
          <a class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800" href={breakPanelUrl}>
            Open break planning
          </a>
        )}
      </div>

      {!showBreakPlanning && (
        <div class="mt-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">Working shifts</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900">{workingShifts.length}</div>
          </div>
          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">Breaks planned</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900">{breaks.length}</div>
          </div>
          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
            <div class="text-xs font-medium uppercase tracking-wide text-slate-500">Missing cover</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900">{uncoveredBreaks.length}</div>
          </div>
        </div>
      )}

      {showBreakPlanning && (
        <>
          <div class="mt-4 flex flex-wrap gap-2">
            <form method="post" action="/api/breaks/autogen-all">
              <input type="hidden" name="date" value={date} />
              <input type="hidden" name="mode" value="overwrite" />
              <button class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800" type="submit">
                Auto-generate ALL (overwrite)
              </button>
            </form>

            <form method="post" action="/api/breaks/autogen-all">
              <input type="hidden" name="date" value={date} />
              <input type="hidden" name="mode" value="missing" />
              <button class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm hover:bg-slate-50" type="submit">
                Auto-generate missing only
              </button>
            </form>

            <form method="post" action="/api/breaks/revalidate">
              <input type="hidden" name="date" value={date} />
              <button class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm hover:bg-slate-50" type="submit">
                Revalidate
              </button>
            </form>

            <form method="post" action="/api/breaks/autofix">
              <input type="hidden" name="date" value={date} />
              <button class="rounded-lg bg-emerald-700 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-800" type="submit">
                Auto-fix covers
              </button>
            </form>
          </div>
          <div class="mt-6 space-y-8">
            {areas.map((area) => {
              const areaShifts = workingShiftViewsByArea.get(area.key) ?? [];

              if (areaShifts.length === 0) return null;

              return (
                <div class="space-y-3">
                  <div class="text-sm font-semibold text-slate-700">{area.label}</div>

                  {areaShifts.map((s) => {
                    const allowance = breakAllowanceMinutes(s.computed_minutes);
                    const rows = breaksByShift.get(s.id) ?? [];
                    const used = plannedBreakMinutesByShift.get(s.id) ?? 0;

                    return (
                      <section class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                        <div class="flex flex-wrap items-center justify-between gap-2">
                          <form method="post" action="/api/breaks/autogen">
                            <input type="hidden" name="date" value={date} />
                            <input type="hidden" name="shiftId" value={s.id} />
                            <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" type="submit">
                              Auto-generate
                            </button>
                          </form>
                          <div>
                            <div class="font-semibold">{s.name}</div>
                            <div class="text-sm text-slate-600">
                              {s.start_time}–{s.end_time ?? '—'} · shift {formatDurationMinutes(s.computed_minutes)} · allowance {allowance}m · planned {used}m
                            </div>
                          </div>
                        </div>

                        <div class="mt-4 overflow-x-auto">
                          <table class="w-full min-w-[780px] border-separate border-spacing-y-2 text-sm">
                            <thead>
                              <tr class="text-left text-slate-600">
                                <th class="px-3">Start</th>
                                <th class="px-3">Duration</th>
                                <th class="px-3">Cover</th>
                                <th class="px-3"></th>
                              </tr>
                            </thead>
                            <tbody>
                              {rows.map((b) => (
                                <tr
                                  class={
                                    b.cover_member_id == null
                                      ? 'bg-rose-50'
                                      : invalidReasonByBreakId.has(b.id)
                                        ? 'bg-amber-50'
                                        : 'bg-white'
                                  }
                                >
                                  <td class="px-3 py-3">
                                    {b.start_time}
                                    {invalidReasonByBreakId.has(b.id) && (
                                      <div class="mt-1 text-xs text-amber-900">{invalidReasonByBreakId.get(b.id)}</div>
                                    )}
                                  </td>
                                  <td class="px-3 py-3">{b.duration_minutes}m</td>
                                  <td class="px-3 py-3">
                                    <form method="post" action="/api/breaks/assign-cover" class="flex items-center gap-2">
                                      <input type="hidden" name="date" value={date} />
                                      <input type="hidden" name="breakId" value={b.id} />
                                      <select class="rounded-lg border border-slate-300 bg-white px-2 py-2" name="coverMemberId">
                                        <option value="" selected={b.cover_member_id == null}>— missing cover —</option>
                                        {(coverCandidatesByBreakId.get(b.id) ?? []).map((cs) => (
                                          <option value={cs.member_id} selected={b.cover_member_id === cs.member_id}>
                                            {cs.name}
                                          </option>
                                        ))}
                                      </select>
                                      <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 hover:bg-slate-50" type="submit">
                                        Set
                                      </button>
                                    </form>
                                  </td>
                                  <td class="px-3 py-3">
                                    <form method="post" action="/api/breaks/delete" onsubmit="return confirm('Delete this break?')">
                                      <input type="hidden" name="date" value={date} />
                                      <input type="hidden" name="breakId" value={b.id} />
                                      <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 hover:bg-slate-50" type="submit">
                                        Delete
                                      </button>
                                    </form>
                                  </td>
                                </tr>
                              ))}

                              <tr class="bg-white">
                                <td class="px-3 py-3" colspan="4">
                                  <form method="post" action="/api/breaks/add" class="flex flex-wrap items-center gap-2">
                                    <input type="hidden" name="date" value={date} />
                                    <input type="hidden" name="shiftId" value={s.id} />

                                    <div class="mr-2 text-sm font-medium text-slate-700">Add break</div>

                                    <input class="w-16 rounded-lg border border-slate-300 bg-white px-2 py-2" type="number" name="hh" min="0" max="23" placeholder="10" required />
                                    <span class="text-slate-600">:</span>
                                    <input class="w-16 rounded-lg border border-slate-300 bg-white px-2 py-2" type="number" name="mm" min="0" max="59" value="00" required />

                                    <select class="rounded-lg border border-slate-300 bg-white px-2 py-2" name="duration">
                                      {[15, 30, 45, 60].map((d) => (
                                        <option value={d}>{d}m</option>
                                      ))}
                                    </select>

                                    <button class="rounded-lg bg-emerald-700 px-3 py-2 font-medium text-white hover:bg-emerald-800" type="submit">
                                      Add
                                    </button>
                                  </form>
                                </td>
                              </tr>
                            </tbody>
                          </table>
                        </div>

                        {used > allowance && (
                          <div class="mt-3 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-900">
                            Planned break time exceeds allowance.
                          </div>
                        )}
                      </section>
                    );
                  })}
                </div>
              );
            })}
          </div>
        </>
      )}
    </div>
  </div>
</Layout>
