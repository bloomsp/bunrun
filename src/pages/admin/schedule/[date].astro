---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { requireRole } from '../../../lib/auth';
import { getDB } from '../../../lib/db';
import { operatingHoursFor, parseHHMM } from '../../../lib/time';
import { addDays, ensureScheduleId, formatLongDateLabel, formatShortDateLabel, startOfWeek, weekDatesFor } from '../../../lib/schedule';
import {
  activeWorkingShiftForMember,
  breakTargetRange,
  buildPlannerContext,
  isAreaCoveredWithoutAssignedCover,
  isCoverAssignmentValid,
  type PlannerBreak
} from '../../../lib/break-planner';
import { coverCandidatesForBreak, loadWeekSummaryByDate, warningsForShift } from '../../../lib/admin-schedule';
import ErrorState from '../../../components/ErrorState.astro';
import { friendlyDbError } from '../../../lib/errors';
import { loadAreas, loadMembers, loadPermissions, loadShiftCoverPriorityRows, loadStatuses } from '../../../lib/lookups';
import Runsheet from '../../../components/Runsheet.astro';
import ShiftTable from '../../../components/admin/ShiftTable.astro';
import BreakTimeline from '../../../components/admin/BreakTimeline.astro';
import BreakPlanningSummary from '../../../components/admin/BreakPlanningSummary.astro';
import ShiftDialogs from '../../../components/admin/ShiftDialogs.astro';
import BreakPlanningPanel from '../../../components/admin/BreakPlanningPanel.astro';

const guard = requireRole(Astro.request, 'admin');
if (!guard.ok) return guard.redirect;

const date = Astro.params.date ?? '';
if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) {
  return new Response('Invalid date', { status: 400 });
}

type Member = {
  id: number;
  name: string;
  active: number;
  all_areas: number;
  default_area_key: string | null;
};

type Area = { key: string; label: string; min_staff?: number };

type ShiftRow = {
  id: number;
  work_block_id: number | null;
  member_id: number;
  name: string;
  home_area_key: string;
  status_key: string;
  shift_role: string;
  start_time: string;
  end_time: string | null;
  shift_minutes: number;
};

type BreakRow = {
  id: number;
  work_block_id: number | null;
  shift_id: number;
  start_time: string;
  duration_minutes: number;
  cover_member_id: number | null;
  cover_member_name: string | null;
};

type WorkBlockRow = {
  id: number;
  schedule_id: number;
  member_id: number;
  member_name: string;
  start_time: string;
  end_time: string;
  total_minutes: number;
};

type Status = { key: string; label: string; blocks_coverage: number };

type ShiftView = ShiftRow & {
  start_minutes: number;
  end_minutes: number | null;
  computed_minutes: number;
  warnings: string[];
  status_label: string;
  role_label: string;
  area_label: string;
  preferred_coverer_names: string[];
};

type BreakListRow = {
  id: number;
  work_block_id: number | null;
  start_time: string;
  duration_minutes: number;
  off_member_name: string;
  off_area_label: string;
  cover_member_name: string | null;
  cover_shift_role: string | null;
  area_covered: boolean;
};

const breakPanelBaseUrl = `/admin/schedule/${date}?panel=breaks`;
const showBreakPlanning = Astro.url.searchParams.get('panel') === 'breaks';

let pageError: ReturnType<typeof friendlyDbError> | null = null;
let weekSummaryByDate = new Map<string, { shiftCount: number; workingCount: number }>();

let shifts: ShiftRow[] = [];
let breaks: BreakRow[] = [];
let workBlocks: WorkBlockRow[] = [];
let members: Member[] = [];
let areas: Area[] = [];
let statuses: Status[] = [];
let shiftCoverPriorityRows: Array<{ shift_id: number; member_id: number; priority: number; name: string }> = [];
let perms: Array<{ member_id: number; area_key: string }> = [];

try {
  const DB = await getDB();

  const scheduleId = await ensureScheduleId(DB, date);

  shifts = (await DB.prepare(
  `SELECT s.id, s.work_block_id, s.member_id, m.name, s.home_area_key, s.status_key, s.shift_role, s.start_time, s.end_time, s.shift_minutes
   FROM shifts s
   JOIN members m ON m.id = s.member_id
   WHERE s.schedule_id=?
   ORDER BY s.home_area_key ASC, m.name COLLATE NOCASE ASC`
).bind(scheduleId).all()).results as ShiftRow[];

  breaks = (await DB.prepare(
  `SELECT b.id, b.work_block_id, b.shift_id, b.start_time, b.duration_minutes, b.cover_member_id,
          coverm.name AS cover_member_name
   FROM breaks b
   JOIN shifts s ON s.id = b.shift_id
   LEFT JOIN members coverm ON coverm.id = b.cover_member_id
   WHERE s.schedule_id=?
   ORDER BY b.start_time ASC`
).bind(scheduleId).all()).results as BreakRow[];

  workBlocks = (await DB.prepare(
  `SELECT wb.id, wb.schedule_id, wb.member_id, m.name AS member_name, wb.start_time, wb.end_time, wb.total_minutes
   FROM work_blocks wb
   JOIN members m ON m.id = wb.member_id
   WHERE wb.schedule_id=?
   ORDER BY wb.start_time ASC, m.name COLLATE NOCASE ASC`
).bind(scheduleId).all()).results as WorkBlockRow[];

  [members, areas, statuses, shiftCoverPriorityRows, perms] = await Promise.all([
    loadMembers(DB, { activeOnly: true }) as Promise<Member[]>,
    loadAreas(DB) as Promise<Area[]>,
    loadStatuses(DB) as Promise<Status[]>,
    loadShiftCoverPriorityRows(DB),
    loadPermissions(DB)
  ]);
  weekSummaryByDate = await loadWeekSummaryByDate(DB, startOfWeek(date), weekDatesFor(date)[6] ?? date);
} catch (error) {
  pageError = friendlyDbError(error);
}

const breaksByShift = new Map<number, BreakRow[]>();
for (const b of breaks) {
  const arr = breaksByShift.get(b.shift_id) ?? [];
  arr.push(b);
  breaksByShift.set(b.shift_id, arr);
}
const breaksByWorkBlock = new Map<number, BreakRow[]>();
for (const b of breaks) {
  if (b.work_block_id == null) continue;
  const arr = breaksByWorkBlock.get(b.work_block_id) ?? [];
  arr.push(b);
  breaksByWorkBlock.set(b.work_block_id, arr);
}

const permsByMember = new Map<number, Set<string>>();
for (const p of perms) {
  const set = permsByMember.get(p.member_id) ?? new Set<string>();
  set.add(p.area_key);
  permsByMember.set(p.member_id, set);
}

const memberById = new Map(members.map((m) => [m.id, m]));
const areaByKey = new Map(areas.map((a) => [a.key, a]));
const statusByKey = new Map(statuses.map((s) => [s.key, s]));
const shiftById = new Map(shifts.map((s) => [s.id, s]));
const workBlockById = new Map(workBlocks.map((block) => [block.id, block]));
const preferredCovererIdsByShift = new Map<number, number[]>();
const preferredCovererNamesByShift = new Map<number, string[]>();
const preferredRankByShiftId = new Map<number, Map<number, number>>();
for (const row of shiftCoverPriorityRows) {
  const ids = preferredCovererIdsByShift.get(row.shift_id) ?? [];
  ids.push(row.member_id);
  preferredCovererIdsByShift.set(row.shift_id, ids);

  const names = preferredCovererNamesByShift.get(row.shift_id) ?? [];
  names.push(row.name);
  preferredCovererNamesByShift.set(row.shift_id, names);
}
for (const [shiftId, ids] of preferredCovererIdsByShift.entries()) {
  preferredRankByShiftId.set(shiftId, new Map(ids.map((memberId, index) => [memberId, index])));
}
const op = operatingHoursFor(date);
const areaMinByKey = new Map(areas.map((a: any) => [a.key, Number((a as any).min_staff ?? 0)]));
const workingShifts = shifts.filter((s) => s.status_key === 'working');
const workingWorkBlockIds = new Set(workBlocks.map((block) => block.id));
// base working counts per area
const shiftViews = shifts.map((s) => {
  const startMinutes = parseHHMM(s.start_time) ?? 0;
  const endMinutes = s.end_time ? parseHHMM(s.end_time) : null;
  const computedMinutes = endMinutes != null ? endMinutes - startMinutes : s.shift_minutes;
  return {
    ...s,
    start_minutes: startMinutes,
    end_minutes: endMinutes,
    computed_minutes: computedMinutes,
    warnings: endMinutes != null ? warningsForShift(s.start_time, s.end_time!, computedMinutes, op) : [],
    status_label: statusByKey.get(s.status_key)?.label ?? s.status_key,
    role_label: s.shift_role === 'floater' ? 'Floater' : 'Normal',
    area_label: areaByKey.get(s.home_area_key)?.label ?? s.home_area_key,
    preferred_coverer_names: preferredCovererNamesByShift.get(s.id) ?? []
  } satisfies ShiftView;
});
const shiftViewById = new Map(shiftViews.map((s) => [s.id, s]));
const shiftViewsByWorkBlock = new Map<number, ShiftView[]>();
for (const shift of shiftViews) {
  if (shift.work_block_id == null) continue;
  const arr = shiftViewsByWorkBlock.get(shift.work_block_id) ?? [];
  arr.push(shift);
  shiftViewsByWorkBlock.set(shift.work_block_id, arr);
}
for (const arr of shiftViewsByWorkBlock.values()) {
  arr.sort((a, b) => a.start_time.localeCompare(b.start_time) || a.id - b.id);
}
const breakPanelUrl = `${breakPanelBaseUrl}#breaks`;
const breakPlanningBlocks = workBlocks
  .map((block) => ({
    ...block,
    shifts: shiftViewsByWorkBlock.get(block.id) ?? []
  }))
  .filter((block) => block.shifts.length > 0);
const breakPlanningBlockIds = new Set(breakPlanningBlocks.map((block) => block.id));
const planner = buildPlannerContext({
  shifts: shifts.map((shift) => ({
    id: shift.id,
    member_id: shift.member_id,
    home_area_key: shift.home_area_key,
    status_key: shift.status_key,
    shift_role: shift.shift_role,
    start_time: shift.start_time,
    end_time: shift.end_time
  })),
  members: members.map((member) => ({
    id: member.id,
    all_areas: member.all_areas
  })),
  perms,
  minByArea: areaMinByKey,
  preferredRankByShiftId
});
const plannerBreaks: PlannerBreak[] = breaks.flatMap((b) => {
  const offShift = shiftById.get(b.shift_id);
  if (!offShift) return [];
  return [{
    id: b.id,
    work_block_id: b.work_block_id,
    shift_id: b.shift_id,
    start_time: b.start_time,
    duration_minutes: Number(b.duration_minutes),
    cover_member_id: b.cover_member_id,
    off_member_id: offShift.member_id,
    off_shift_id: offShift.id,
    off_area_key: offShift.home_area_key
  }];
});
const plannerBreakById = new Map(plannerBreaks.map((row) => [row.id, row]));
const areaCoveredByBreakId = new Map(
  plannerBreaks.map((row) => [row.id, row.cover_member_id == null && isAreaCoveredWithoutAssignedCover(planner, plannerBreaks, row)])
);
const uncoveredBreaks = plannerBreaks.filter((b) =>
  (b.work_block_id != null ? workingWorkBlockIds.has(b.work_block_id) : true) &&
  !isCoverAssignmentValid(planner, plannerBreaks, b, b.cover_member_id)
);
const plannedBreakMinutesByWorkBlock = new Map<number, number>();
for (const [workBlockId, rows] of breaksByWorkBlock.entries()) {
  plannedBreakMinutesByWorkBlock.set(
    workBlockId,
    rows.reduce((sum, row) => sum + Number(row.duration_minutes), 0)
  );
}

const invalidCoverBreaks: { id: number; reason: string }[] = [];
if (showBreakPlanning) {
  for (const b of plannerBreaks) {
    if (b.work_block_id == null || !breakPlanningBlockIds.has(b.work_block_id)) continue;
    if (b.cover_member_id == null) continue;
    if (!isCoverAssignmentValid(planner, plannerBreaks, b, b.cover_member_id)) {
      invalidCoverBreaks.push({ id: b.id, reason: 'Cover assignment needs review' });
    }
  }
}

const invalidReasonByBreakId = new Map(invalidCoverBreaks.map((x) => [x.id, x.reason]));
const chronologicalBreakRows = plannerBreaks
  .map((row) => {
    const offShift = shiftById.get(row.shift_id);
    const offMember = offShift ? memberById.get(offShift.member_id) : null;
    const coverMember = row.cover_member_id != null ? memberById.get(row.cover_member_id) : null;
    const coverShift = row.cover_member_id != null
      ? activeWorkingShiftForMember(planner, row.cover_member_id, breakTargetRange(row) ?? { start: -1, end: -1 })
      : null;
    return {
      id: row.id,
      work_block_id: row.work_block_id,
      start_time: row.start_time,
      duration_minutes: row.duration_minutes,
      off_member_name: offMember?.name ?? 'Unknown member',
      off_area_label: areaByKey.get(row.off_area_key)?.label ?? row.off_area_key,
      cover_member_name: coverMember?.name ?? null,
      cover_shift_role: coverShift?.shift_role ?? null,
      area_covered: areaCoveredByBreakId.get(row.id) === true
    } satisfies BreakListRow;
  })
  .sort((a, b) => (parseHHMM(a.start_time) ?? 0) - (parseHHMM(b.start_time) ?? 0) || a.off_member_name.localeCompare(b.off_member_name));

const notice = Astro.url.searchParams.get('notice');
const errorMsg = Astro.url.searchParams.get('error');
const weekStart = startOfWeek(date);
const weekDates = weekDatesFor(date);
const previousWeekDate = addDays(weekStart, -7);
const nextWeekDate = addDays(weekStart, 7);
const weekEnd = weekDates[6] ?? date;

const coverCandidatesByBreakId = new Map<number, Member[]>();
if (showBreakPlanning) {
  for (const block of breakPlanningBlocks) {
    for (const b of breaksByWorkBlock.get(block.id) ?? []) {
      const offShift = shiftViewById.get(b.shift_id);
      if (!offShift) continue;
      coverCandidatesByBreakId.set(b.id, coverCandidatesForBreak({
        planner,
        plannerBreaks,
        preferredRankByShiftId,
        members,
        workingShifts,
        offShift,
        targetBreakId: b.id
      }));
    }
  }
}
---

<Layout title={`Schedule ${date} | Bunrun`}>
  <script src="/js/schedule-time.js?v=4" defer></script>
  {pageError ? (
    <div class="px-3 py-10">
      <ErrorState title={pageError.title} message={pageError.message} details={pageError.details} />
    </div>
  ) : (
  <div class="mx-auto max-w-[96rem] px-3 py-10">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight">Schedule</h1>
        <div class="mt-1 text-slate-700">{formatLongDateLabel(date)}</div>
        <div class="mt-1 text-sm text-slate-500">Week of {weekStart}</div>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href="/admin/schedule">Change date</a>
        <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href={`/admin/schedule/${previousWeekDate}`}>
          Previous week
        </a>
        <a class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" href={`/admin/schedule/${nextWeekDate}`}>
          Next week
        </a>
      </div>
    </div>

    <div class="mt-6 overflow-x-auto">
      <div class="flex min-w-max gap-3">
        {weekDates.map((tabDate) => {
          const summary = weekSummaryByDate.get(tabDate) ?? { shiftCount: 0, workingCount: 0 };
          const active = tabDate === date;
          return (
            <a
              class:list={[
                'min-w-[132px] rounded-2xl border px-4 py-3 text-left transition',
                active
                  ? 'border-emerald-600 bg-emerald-50 text-emerald-950 shadow-sm'
                  : 'border-slate-200 bg-white text-slate-800 hover:border-slate-300 hover:bg-slate-50'
              ]}
              href={`/admin/schedule/${tabDate}`}
            >
              <div class="text-sm font-semibold">{formatShortDateLabel(tabDate)}</div>
              <div class="mt-1 text-xs text-slate-600">
                {summary.shiftCount} shift{summary.shiftCount === 1 ? '' : 's'}
              </div>
              <div class="mt-0.5 text-xs text-slate-500">
                {summary.workingCount} working
              </div>
            </a>
          );
        })}
      </div>
    </div>

    {op && (
      <div class="mt-3 text-sm text-slate-600">
        Operating hours: {Math.floor(op.open / 60).toString().padStart(2, '0')}:{String(op.open % 60).padStart(2, '0')}
        – {Math.floor(op.close / 60).toString().padStart(2, '0')}:{String(op.close % 60).padStart(2, '0')}
      </div>
    )}

    {errorMsg && (
      <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 p-4 text-rose-900">
        <div class="font-semibold">Action blocked</div>
        <div class="mt-1 text-sm">{errorMsg}</div>
      </div>
    )}

    {notice && (
      <div class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-900">
        <div class="font-semibold">Updated</div>
        <div class="mt-1 text-sm">{notice}</div>
      </div>
    )}

    {(uncoveredBreaks.length > 0 || invalidCoverBreaks.length > 0) && (
      <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 p-4 text-rose-900">
        <div class="font-semibold">Schedule needs attention</div>
        <div class="mt-1 text-sm">
          {uncoveredBreaks.length > 0 && (
            <span>
              {uncoveredBreaks.length} break{uncoveredBreaks.length === 1 ? '' : 's'} {uncoveredBreaks.length === 1 ? 'is' : 'are'} missing cover.
            </span>
          )}
          {invalidCoverBreaks.length > 0 && (
            <span class="ml-2">
              {invalidCoverBreaks.length} break{invalidCoverBreaks.length === 1 ? '' : 's'} {invalidCoverBreaks.length === 1 ? 'has' : 'have'} invalid cover.
            </span>
          )}
          <a class="ml-2 underline" href={breakPanelUrl}>Review break planning</a>
        </div>
      </div>
    )}

    <div class="mt-8 grid gap-4 xl:grid-cols-2">
      <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-medium">Copy day</h2>
        <p class="mt-2 text-sm text-slate-600">Replace this day's shifts and breaks with another date.</p>
        <form class="mt-4 flex flex-wrap items-end gap-3" method="post" action="/api/schedule/copy-day" onsubmit={`return confirm('Copy the selected day into ${date}? This overwrites the current day.')`}>
          <input type="hidden" name="targetDate" value={date} />
          <label class="block">
            <div class="text-sm font-medium text-slate-800">Source day</div>
            <input class="mt-1 rounded-lg border border-slate-300 bg-white px-3 py-2" type="date" name="sourceDate" value={addDays(date, -7)} required />
          </label>
          <button class="rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800" type="submit">
            Copy into {date}
          </button>
        </form>
      </section>

      <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-medium">Copy week</h2>
        <p class="mt-2 text-sm text-slate-600">Replace every day in this week with the matching day from another week.</p>
        <form class="mt-4 flex flex-wrap items-end gap-3" method="post" action="/api/schedule/copy-week" onsubmit={`return confirm('Copy the selected week into the week of ${weekStart}? This overwrites all 7 days.')`}>
          <input type="hidden" name="targetWeekDate" value={weekStart} />
          <label class="block">
            <div class="text-sm font-medium text-slate-800">Source week</div>
            <input class="mt-1 rounded-lg border border-slate-300 bg-white px-3 py-2" type="date" name="sourceWeekDate" value={addDays(weekStart, -7)} required />
          </label>
          <button class="rounded-lg bg-emerald-700 px-4 py-2.5 text-sm font-medium text-white hover:bg-emerald-800" type="submit">
            Copy into week of {weekStart}
          </button>
        </form>
      </section>
    </div>

    <ShiftTable shifts={shiftViews} date={date} preferredCovererIdsByShift={preferredCovererIdsByShift} />

    <ShiftDialogs date={date} members={members} areas={areas} statuses={statuses} />

    <div class="mt-8 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <Runsheet
        date={date}
        areas={areas}
        shifts={shifts}
        breaks={breaks.map((row) => ({
          ...row,
          area_covered: areaCoveredByBreakId.get(row.id) === true
        }))}
      />
    </div>

    <BreakTimeline rows={chronologicalBreakRows} />

    <BreakPlanningSummary
      showBreakPlanning={showBreakPlanning}
      date={date}
      breakPanelUrl={breakPanelUrl}
      workingShiftCount={workingShifts.length}
      breakCount={breaks.length}
      uncoveredCount={uncoveredBreaks.length}
    />

    <div class="mt-4 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <BreakPlanningPanel
        showBreakPlanning={showBreakPlanning}
        breakPlanningBlocks={breakPlanningBlocks}
        breaksByWorkBlock={breaksByWorkBlock}
        plannedBreakMinutesByWorkBlock={plannedBreakMinutesByWorkBlock}
        breakPanelUrl={breakPanelUrl}
        date={date}
        shiftViewById={shiftViewById}
        isBreakValid={(breakId, coverMemberId) => {
          const row = plannerBreakById.get(breakId);
          return row ? isCoverAssignmentValid(planner, plannerBreaks, row, coverMemberId) : false;
        }}
        invalidReasonByBreakId={invalidReasonByBreakId}
        areaCoveredByBreakId={areaCoveredByBreakId}
        coverCandidatesByBreakId={coverCandidatesByBreakId}
      />
    </div>
  </div>
  <script is:inline>
    const shiftDialogs = {
      add: document.querySelector('[data-shift-dialog="add"]'),
      edit: document.querySelector('[data-shift-dialog="edit"]')
    };

    const showShiftDialog = (dialog) => dialog && typeof dialog.showModal === 'function' && dialog.showModal();
    const closeShiftDialog = (dialog) => dialog && typeof dialog.close === 'function' && dialog.close();

    document.querySelector('[data-open-add-shift]')?.addEventListener('click', () => showShiftDialog(shiftDialogs.add));

    document.querySelectorAll('[data-close-shift-dialog]').forEach((button) => {
      button.addEventListener('click', () => closeShiftDialog(button.closest('dialog')));
    });

    document.querySelectorAll('[data-open-edit-shift]').forEach((button) => {
      button.addEventListener('click', () => {
        const dialog = shiftDialogs.edit;
        if (!dialog) return;
        const form = dialog.querySelector('form');
        if (!form) return;
        const memberId = button.dataset.memberId || '';

        form.querySelector('input[name="shiftId"]').value = button.dataset.shiftId || '';
        form.querySelector('select[name="homeAreaKey"]').value = button.dataset.homeAreaKey || '';
        form.querySelector('select[name="statusKey"]').value = button.dataset.statusKey || 'working';
        form.querySelector('select[name="shiftRole"]').value = button.dataset.shiftRole || 'normal';
        form.querySelector('input[name="startTime"]').value = button.dataset.startTime || '';
        form.querySelector('input[name="endTime"]').value = button.dataset.endTime || '';
        dialog.querySelector('[data-edit-shift-member]').textContent = `Update ${button.dataset.memberName || 'this member'}'s shift details and preferred coverers.`;

        const preferred = (button.dataset.preferredCoverers || '').split(',').filter(Boolean);
        form.querySelectorAll('select[name="preferredCovererIds"]').forEach((select, index) => {
          Array.from(select.options).forEach((option) => {
            option.disabled = Boolean(memberId) && option.value === memberId;
          });
          select.value = preferred[index] || '';
        });

        showShiftDialog(dialog);
      });
    });
  </script>
  )}
</Layout>
