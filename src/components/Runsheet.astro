---
import { buildTimeSlots, RUNSHEET_END, RUNSHEET_START, RUNSHEET_STEP_MIN } from '../lib/runsheet';
import { operatingHoursFor, parseHHMM } from '../lib/time';

export type Area = { key: string; label: string; min_staff?: number };
export type Shift = {
  id: number;
  member_id: number;
  name: string;
  home_area_key: string;
  status_key: string;
  start_time: string;
  end_time: string | null;
};
export type Break = {
  id: number;
  shift_id: number;
  start_time: string;
  duration_minutes: number;
  cover_member_name?: string | null;
};

export interface Props {
  date: string;
  areas: Area[];
  shifts: Shift[];
  breaks: Break[];
  variant?: 'default' | 'print';
}

const { date, areas, shifts, breaks, variant = 'default' } = Astro.props;

const slots = buildTimeSlots();
const startM = parseHHMM(RUNSHEET_START) ?? 360;
const timelineColumns = `repeat(${slots.length}, var(--runsheet-slot-width))`;
const isPrint = variant === 'print';

const breaksByShift = new Map<number, Break[]>();
for (const b of breaks) {
  const arr = breaksByShift.get(b.shift_id) ?? [];
  arr.push(b);
  breaksByShift.set(b.shift_id, arr);
}

const areaPalette: Record<string, string> = {
  'service-desk': 'bg-emerald-100 border-emerald-300',
  'registers': 'bg-amber-100 border-amber-300',
  'tool-shop': 'bg-sky-100 border-sky-300',
  'nursery': 'bg-lime-100 border-lime-300',
  'cafe': 'bg-fuchsia-100 border-fuchsia-300',
  'car-park': 'bg-orange-100 border-orange-300',
  'front-door': 'bg-teal-100 border-teal-300',
  'greeters': 'bg-rose-100 border-rose-300'
};

const printAreaPalette: Record<string, string> = {
  'service-desk': 'bg-slate-200 border-slate-400',
  'registers': 'bg-zinc-200 border-zinc-400',
  'tool-shop': 'bg-gray-200 border-gray-400',
  'nursery': 'bg-stone-200 border-stone-400',
  'cafe': 'bg-neutral-200 border-neutral-400',
  'car-park': 'bg-slate-300 border-slate-500',
  'front-door': 'bg-zinc-300 border-zinc-500',
  'greeters': 'bg-gray-300 border-gray-500'
};

function compactSlotLabel(mins: number) {
  const hour = Math.floor(mins / 60);
  const minute = mins % 60;
  if (minute === 0) return String(hour).padStart(2, '0');
  return '•';
}

function leftSlots(mins: number) {
  return (mins - startM) / RUNSHEET_STEP_MIN;
}

function widthSlots(start: number, end: number) {
  return ((end - start) / RUNSHEET_STEP_MIN) + 1;
}

function breakMarker(duration: number) {
  if (duration <= 15) return 'X';
  if (duration <= 30) return 'X\nX';
  if (duration <= 45) return 'X\nX\nX';
  return 'X\nX\nX\nX';
}

function breakTitle(b: Break) {
  const coverText = b.cover_member_name ? ` · Covered by ${b.cover_member_name}` : '';
  return `Break ${b.start_time} (${b.duration_minutes}m)${coverText}`;
}

function formatShiftLength(startTime: string, endTime: string | null) {
  const start = parseHHMM(startTime);
  const end = endTime ? parseHHMM(endTime) : null;
  if (start == null || end == null || end <= start) return null;
  const duration = end - start;
  const hours = Math.floor(duration / 60);
  const minutes = duration % 60;
  if (minutes === 0) return `${hours}h`;
  if (hours === 0) return `${minutes}m`;
  return `${hours}h ${minutes}m`;
}
---

<section class:list={['runsheet mt-6', isPrint && 'runsheet-print-mode']} style={`--runsheet-slot-count:${slots.length};`}>
  <style>
    .runsheet {
      --runsheet-name-col: 160px;
      --runsheet-slot-width: 32px;
      --runsheet-row-height: 40px;
      --runsheet-header-height: 40px;
      --runsheet-marker-width: 12px;
      --runsheet-grid-width: calc(var(--runsheet-slot-count) * var(--runsheet-slot-width));
    }

    .runsheet-area {
      break-inside: avoid-page;
      page-break-inside: avoid;
    }

    .runsheet-shell {
      width: 100%;
    }

    .runsheet-grid {
      min-width: calc(var(--runsheet-name-col) + var(--runsheet-grid-width));
    }

    .runsheet-print-mode {
      --runsheet-name-col: 136px;
      --runsheet-slot-width: 20px;
      --runsheet-row-height: 30px;
      --runsheet-header-height: 30px;
      --runsheet-marker-width: 10px;
    }

    .runsheet-print-mode .runsheet-shell {
      overflow: visible;
      border-color: #334155;
      border-radius: 0;
    }

    .runsheet-print-mode .runsheet-grid {
      min-width: calc(var(--runsheet-name-col) + var(--runsheet-grid-width));
    }

    .runsheet-print-mode .runsheet-time-label {
      font-size: 9px;
    }

    .runsheet-print-mode .runsheet-person-cell,
    .runsheet-print-mode .runsheet-area-label {
      padding-top: 0.3rem;
      padding-bottom: 0.3rem;
    }

    .runsheet-print-mode .runsheet-person-cell {
      font-size: 12px;
    }

    .runsheet-print-mode .runsheet-shift-block {
      top: 3px;
      height: 24px;
    }

    .runsheet-print-mode .runsheet-break-marker {
      font-size: 8px;
      line-height: 8px;
    }

    @page {
      size: A4 landscape;
      margin: 8mm;
    }

    @media print {
      .runsheet {
        --runsheet-name-col: 136px;
        --runsheet-slot-width: 24px;
        --runsheet-row-height: 34px;
        --runsheet-header-height: 34px;
        --runsheet-marker-width: 12px;
      }

      .runsheet-shell {
        overflow: visible !important;
        border-radius: 0.5rem;
      }

      .runsheet-summary {
        font-size: 10px;
      }

      .runsheet-time-label {
        font-size: 9px;
      }

      .runsheet-person-cell {
        padding: 0.35rem 0.5rem;
      }

      .runsheet-area-label {
        padding: 0.35rem 0.5rem;
        font-size: 11px;
      }

      .runsheet-shift-block {
        top: 4px;
        height: 24px;
      }

      .runsheet-break-marker {
        font-size: 9px;
        line-height: 9px;
      }

      .runsheet-legend {
        font-size: 9px;
      }
    }
  </style>

  <div class="flex items-baseline justify-between gap-3">
    <h2 class="text-lg font-semibold">Runsheet</h2>
    <div class="runsheet-summary text-sm text-slate-600">Date: {date} · {RUNSHEET_START}–{RUNSHEET_END} · {RUNSHEET_STEP_MIN} min blocks</div>
  </div>

  <div class:list={['runsheet-shell mt-4 rounded-xl border bg-white', isPrint ? 'border-slate-700' : 'overflow-x-auto border-slate-200']}>
    <div class="runsheet-grid print:min-w-0">
      <div class="grid" style="grid-template-columns: var(--runsheet-name-col) var(--runsheet-grid-width);">
        <div class="sticky left-0 z-20 border-b border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700">Area / Person</div>
        <div class="border-b border-slate-200 bg-white">
          <div class="grid" style={`grid-template-columns: ${timelineColumns}; height: var(--runsheet-header-height);`}>
            {slots.map((s) => (
              <div class="runsheet-time-label grid place-items-center border-l border-slate-200 px-2 text-center text-[12px] text-slate-600">
                {compactSlotLabel(s.t)}
              </div>
            ))}
          </div>
        </div>
      </div>

      {areas.map((a) => {
        const areaShifts = shifts
          .filter((s) => s.home_area_key === a.key)
          .sort((x, y) => x.name.localeCompare(y.name));
        if (areaShifts.length === 0) return null;

        return (
          <div class="runsheet-area border-t border-slate-200">
            <div class="grid" style="grid-template-columns: var(--runsheet-name-col) var(--runsheet-grid-width);">
              <div class="runsheet-area-label sticky left-0 z-10 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-800">
                {a.label}
              </div>
                <div class="bg-slate-50">
                  <div class="grid" style={`grid-template-columns: ${timelineColumns}; height: var(--runsheet-header-height);`}>
                    {slots.map((s) => (
                      <div class="runsheet-time-label grid place-items-center border-l border-slate-200 px-2 text-center text-[12px] text-slate-600">
                        {compactSlotLabel(s.t)}
                      </div>
                    ))}
                  </div>
                </div>
            </div>

            {areaShifts.map((s) => {
              const start = parseHHMM(s.start_time) ?? startM;
              const end = s.end_time ? parseHHMM(s.end_time) ?? start : start;
              const bks = breaksByShift.get(s.id) ?? [];
              const palette = (isPrint ? printAreaPalette : areaPalette)[s.home_area_key] ?? 'bg-slate-100 border-slate-300';

              return (
                <div class="grid" style="grid-template-columns: var(--runsheet-name-col) var(--runsheet-grid-width);">
                  <div class="runsheet-person-cell sticky left-0 z-10 border-t border-slate-100 bg-white px-3 py-2 text-sm">
                    <div class="flex items-center justify-between gap-2">
                      <span class={s.status_key === 'sick' ? 'font-semibold text-rose-700' : 'font-medium text-slate-900'}>
                        {s.name}
                      </span>
                      {s.status_key === 'sick' && <span class="rounded bg-rose-100 px-2 py-0.5 text-xs text-rose-900">Sick</span>}
                    </div>
                    <div class="mt-0.5 text-xs text-slate-600">
                      {s.start_time}–{s.end_time ?? '—'}{formatShiftLength(s.start_time, s.end_time) ? ` · ${formatShiftLength(s.start_time, s.end_time)}` : ''}
                    </div>
                  </div>

                  <div
                    class="relative border-t border-slate-100"
                    style="height: var(--runsheet-row-height); width: var(--runsheet-grid-width);"
                  >
                    {slots.map((sl, i) => (
                      <div
                        class="absolute top-0 h-full border-l border-slate-100"
                        style={`left: calc(${i} * var(--runsheet-slot-width));`}
                      ></div>
                    ))}

                    {s.status_key !== 'sick' && (
                      <div
                        class={`runsheet-shift-block absolute top-[6px] h-[30px] rounded-md border ${palette}`}
                        style={`left: calc(${leftSlots(start)} * var(--runsheet-slot-width)); width: calc(${widthSlots(start, end)} * var(--runsheet-slot-width));`}
                        title={`${s.start_time}–${s.end_time}`}
                      ></div>
                    )}

                    {s.status_key !== 'sick' &&
                      bks.map((b) => {
                        const bm = parseHHMM(b.start_time);
                        if (bm == null) return null;
                        return (
                          <div
                            class="runsheet-break-marker absolute inset-y-0 flex items-center justify-center text-center text-[10px] font-black leading-[10px] whitespace-pre-line text-slate-900"
                            style={`left: calc((${leftSlots(bm)} + 0.5) * var(--runsheet-slot-width) - (var(--runsheet-marker-width) / 2)); width: var(--runsheet-marker-width);`}
                            title={breakTitle(b)}
                          >
                            {breakMarker(b.duration_minutes)}
                          </div>
                        );
                      })}
                  </div>
                </div>
              );
            })}
          </div>
        );
      })}
    </div>
  </div>

  <div class="runsheet-legend mt-2 text-xs text-slate-600">
    Break marker legend: 15m = X · 30m = stacked X\nX · 60m = stacked X\nX\nX\nX
  </div>
</section>
