---
import { buildTimeSlots, RUNSHEET_END, RUNSHEET_START, RUNSHEET_STEP_MIN } from '../lib/runsheet';
import { operatingHoursFor, parseHHMM } from '../lib/time';

export type Area = { key: string; label: string; min_staff?: number };
export type Shift = {
  id: number;
  member_id: number;
  name: string;
  home_area_key: string;
  status_key: string;
  start_time: string;
  end_time: string | null;
};
export type Break = {
  id: number;
  shift_id: number;
  start_time: string;
  duration_minutes: number;
};

export interface Props {
  date: string;
  areas: Area[];
  shifts: Shift[];
  breaks: Break[];
  variant?: 'default' | 'print';
}

const { date, areas, shifts, breaks, variant = 'default' } = Astro.props;

const slots = buildTimeSlots();
const startM = parseHHMM(RUNSHEET_START) ?? 360;
const timelineColumns = `repeat(${slots.length}, var(--runsheet-slot-width))`;
const printHours = (() => {
  const op = operatingHoursFor(date);
  const open = op?.open ?? startM;
  const close = op?.close ?? (parseHHMM(RUNSHEET_END) ?? (21 * 60 + 15));
  const hours: Array<{ start: number; label: string }> = [];
  for (let t = open; t <= close - 15; t += 60) {
    const hour = Math.floor(t / 60);
    const suffix = hour >= 12 ? 'pm' : 'am';
    const hour12 = ((hour + 11) % 12) + 1;
    hours.push({ start: t, label: `${hour12}${suffix}` });
  }
  return hours;
})();

const breaksByShift = new Map<number, Break[]>();
for (const b of breaks) {
  const arr = breaksByShift.get(b.shift_id) ?? [];
  arr.push(b);
  breaksByShift.set(b.shift_id, arr);
}

const areaPalette: Record<string, string> = {
  'service-desk': 'bg-emerald-100 border-emerald-300',
  'registers': 'bg-amber-100 border-amber-300',
  'tool-shop': 'bg-sky-100 border-sky-300',
  'nursery': 'bg-lime-100 border-lime-300',
  'cafe': 'bg-fuchsia-100 border-fuchsia-300',
  'car-park': 'bg-orange-100 border-orange-300',
  'front-door': 'bg-teal-100 border-teal-300',
  'greeters': 'bg-rose-100 border-rose-300'
};

function leftSlots(mins: number) {
  return (mins - startM) / RUNSHEET_STEP_MIN;
}

function widthSlots(start: number, end: number) {
  return ((end - start) / RUNSHEET_STEP_MIN) + 1;
}

function markerCellCenter(mins: number) {
  return Math.floor(leftSlots(mins)) + 0.5;
}

function breakMarker(duration: number) {
  if (duration <= 15) return 'X';
  if (duration <= 30) return 'X\nX';
  if (duration <= 45) return 'X\nX\nX';
  return 'X\nX\nX\nX';
}

function printLeftHours(mins: number) {
  const printStart = printHours[0]?.start ?? startM;
  return (mins - printStart) / 60;
}

function overlapsHour(start: number, end: number, hourStart: number) {
  const hourEnd = hourStart + 60;
  return start < hourEnd && hourStart < end;
}

function formatShiftLength(startTime: string, endTime: string | null) {
  const start = parseHHMM(startTime);
  const end = endTime ? parseHHMM(endTime) : null;
  if (start == null || end == null || end <= start) return null;
  const duration = end - start;
  const hours = Math.floor(duration / 60);
  const minutes = duration % 60;
  if (minutes === 0) return `${hours}h`;
  if (hours === 0) return `${minutes}m`;
  return `${hours}h ${minutes}m`;
}
---

{variant === 'print' ? (
  <section class="runsheet-print mt-6">
    <style>
      .runsheet-print {
        --print-area-col: 82px;
        --print-name-col: 110px;
        --print-time-col: 74px;
        --print-hour-col: minmax(0, 1fr);
        --print-row-height: 26px;
      }

      .runsheet-print-grid {
        display: grid;
        grid-template-columns:
          var(--print-area-col)
          var(--print-name-col)
          var(--print-time-col)
          repeat(${printHours.length}, var(--print-hour-col));
      }

      .runsheet-print-cell {
        border-right: 1px solid #1f2937;
        border-bottom: 1px solid #1f2937;
        min-height: var(--print-row-height);
        font-size: 11px;
      }

      .runsheet-print-head {
        background: #e5e7eb;
        font-weight: 700;
        text-align: center;
      }

      .runsheet-print-sticky {
        display: flex;
        align-items: center;
        padding: 0 0.35rem;
      }

      .runsheet-print-hours {
        position: relative;
        grid-column: 4 / -1;
        min-height: var(--print-row-height);
      }

      .runsheet-print-hours-grid {
        display: grid;
        grid-template-columns: repeat(${printHours.length}, 1fr);
        height: 100%;
      }

      .runsheet-print-hour {
        border-right: 1px solid #1f2937;
      }

      .runsheet-print-hour.is-active.area-tone-0 { background: #d1d5db; }
      .runsheet-print-hour.is-active.area-tone-1 { background: repeating-linear-gradient(45deg, #d1d5db, #d1d5db 4px, #f3f4f6 4px, #f3f4f6 8px); }
      .runsheet-print-hour.is-active.area-tone-2 { background: repeating-linear-gradient(90deg, #d1d5db, #d1d5db 3px, #f3f4f6 3px, #f3f4f6 6px); }
      .runsheet-print-hour.is-active.area-tone-3 { background: repeating-linear-gradient(0deg, #d1d5db, #d1d5db 3px, #f3f4f6 3px, #f3f4f6 6px); }
      .runsheet-print-hour.is-active.area-tone-4 { background: radial-gradient(circle, #d1d5db 18%, transparent 19%) 0 0/8px 8px, #f3f4f6; }

      .runsheet-print-marker {
        position: absolute;
        top: 50%;
        transform: translate(-50%, -50%);
        font-weight: 700;
        font-size: 11px;
        line-height: 1;
      }

      @media print {
        .runsheet-print {
          margin-top: 0;
        }

        .runsheet-print {
          --print-area-col: 76px;
          --print-name-col: 100px;
          --print-time-col: 64px;
          --print-row-height: 22px;
        }

        .runsheet-print-cell {
          font-size: 9px;
        }

        .runsheet-print-marker {
          font-size: 10px;
        }
      }
    </style>

    <div class="mb-2 text-sm text-slate-600">Date: {date}</div>
    <div class="overflow-x-auto rounded-xl border border-slate-800 bg-white">
      <div class="runsheet-print-grid border-l border-t border-slate-800">
        <div class="runsheet-print-cell runsheet-print-head runsheet-print-sticky">Area</div>
        <div class="runsheet-print-cell runsheet-print-head runsheet-print-sticky">Name</div>
        <div class="runsheet-print-cell runsheet-print-head runsheet-print-sticky">Shift</div>
        {printHours.map((hour) => (
          <div class="runsheet-print-cell runsheet-print-head">{hour.label}</div>
        ))}

        {areas.flatMap((area, areaIndex) =>
          shifts
            .filter((shift) => shift.home_area_key === area.key)
            .sort((a, b) => a.name.localeCompare(b.name))
            .map((shift) => {
              const start = parseHHMM(shift.start_time) ?? startM;
              const end = shift.end_time ? (parseHHMM(shift.end_time) ?? start) : start;
              const toneClass = `area-tone-${areaIndex % 5}`;
              const shiftBreaks = breaksByShift.get(shift.id) ?? [];
              return (
                <>
                  <div class="runsheet-print-cell runsheet-print-sticky">{area.label}</div>
                  <div class="runsheet-print-cell runsheet-print-sticky">{shift.name}</div>
                  <div class="runsheet-print-cell runsheet-print-sticky">
                    {shift.start_time}–{shift.end_time ?? '—'}{formatShiftLength(shift.start_time, shift.end_time) ? ` (${formatShiftLength(shift.start_time, shift.end_time)})` : ''}
                  </div>
                  <div class="runsheet-print-cell runsheet-print-hours">
                    <div class="runsheet-print-hours-grid">
                      {printHours.map((hour) => (
                        <div class:list={['runsheet-print-hour', overlapsHour(start, end, hour.start) && 'is-active', toneClass]}></div>
                      ))}
                    </div>
                    {shiftBreaks.map((breakRow) => {
                      const breakStart = parseHHMM(breakRow.start_time);
                      if (breakStart == null) return null;
                      return (
                        <div
                          class="runsheet-print-marker"
                          style={`left: calc(${printLeftHours(breakStart)} * (100% / ${printHours.length}));`}
                          title={`Break ${breakRow.start_time}`}
                        >
                          X
                        </div>
                      );
                    })}
                  </div>
                </>
              );
            })
        )}
      </div>
    </div>
  </section>
) : (

<section class="runsheet mt-6" style={`--runsheet-slot-count:${slots.length};`}>
  <style>
    .runsheet {
      --runsheet-name-col: 160px;
      --runsheet-slot-min-width: 24px;
      --runsheet-slot-width: max(var(--runsheet-slot-min-width), calc((100% - var(--runsheet-name-col)) / var(--runsheet-slot-count)));
      --runsheet-row-height: 40px;
      --runsheet-header-height: 40px;
      --runsheet-marker-width: 12px;
      --runsheet-grid-width: calc(var(--runsheet-slot-count) * var(--runsheet-slot-width));
    }

    .runsheet-area {
      break-inside: avoid-page;
      page-break-inside: avoid;
    }

    .runsheet-shell {
      width: 100%;
    }

    .runsheet-grid {
      width: 100%;
      min-width: calc(var(--runsheet-name-col) + (var(--runsheet-slot-count) * var(--runsheet-slot-min-width)));
    }

    .runsheet-time-label {
      font-size: 10px;
      line-height: 1;
    }

    .runsheet-time-label.is-half-hour {
      color: #64748b;
      font-weight: 500;
    }

    .runsheet-time-label.is-hour {
      font-weight: 700;
      color: #334155;
    }

    @page {
      size: A4 landscape;
      margin: 8mm;
    }

    @media print {
      .runsheet {
        --runsheet-name-col: 136px;
        --runsheet-slot-width: 24px;
        --runsheet-row-height: 34px;
        --runsheet-header-height: 34px;
        --runsheet-marker-width: 12px;
      }

      .runsheet-shell {
        overflow: visible !important;
        border-radius: 0.5rem;
      }

      .runsheet-summary {
        font-size: 10px;
      }

      .runsheet-time-label {
        font-size: 9px;
      }

      .runsheet-person-cell {
        padding: 0.35rem 0.5rem;
      }

      .runsheet-area-label {
        padding: 0.35rem 0.5rem;
        font-size: 11px;
      }

      .runsheet-shift-block {
        top: 4px;
        height: 24px;
      }

      .runsheet-break-marker {
        font-size: 9px;
        line-height: 9px;
      }

      .runsheet-legend {
        font-size: 9px;
      }
    }
  </style>

  <div class="flex items-baseline justify-between gap-3">
    <h2 class="text-lg font-semibold">Runsheet</h2>
    <div class="runsheet-summary text-sm text-slate-600">Date: {date} · {RUNSHEET_START}–{RUNSHEET_END} · {RUNSHEET_STEP_MIN} min blocks</div>
  </div>

  <div class="runsheet-shell mt-4 overflow-x-auto rounded-xl border border-slate-200 bg-white">
    <div class="runsheet-grid print:min-w-0">
      <div class="grid" style="grid-template-columns: var(--runsheet-name-col) minmax(0, var(--runsheet-grid-width));">
        <div class="sticky left-0 z-20 border-b border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700">Area / Person</div>
        <div class="border-b border-slate-200 bg-white">
          <div class="grid" style={`grid-template-columns: ${timelineColumns}; height: var(--runsheet-header-height);`}>
            {slots.map((s) => (
              <div
                class:list={[
                  'runsheet-time-label grid place-items-center border-l border-slate-200 px-1 text-center',
                  s.t % 60 === 0 ? 'is-hour' : 'is-half-hour'
                ]}
              >
                {s.label}
              </div>
            ))}
          </div>
        </div>
      </div>

      {areas.map((a) => {
        const areaShifts = shifts
          .filter((s) => s.home_area_key === a.key)
          .sort((x, y) => x.name.localeCompare(y.name));
        if (areaShifts.length === 0) return null;

        return (
          <div class="runsheet-area border-t border-slate-200">
            <div class="grid" style="grid-template-columns: var(--runsheet-name-col) minmax(0, var(--runsheet-grid-width));">
              <div class="runsheet-area-label sticky left-0 z-10 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-800">
                {a.label}
              </div>
                <div class="bg-slate-50">
                  <div class="grid" style={`grid-template-columns: ${timelineColumns}; height: var(--runsheet-header-height);`}>
                    {slots.map((s) => (
                      <div
                        class:list={[
                          'runsheet-time-label grid place-items-center border-l border-slate-200 px-1 text-center',
                          s.t % 60 === 0 ? 'is-hour' : 'is-half-hour'
                        ]}
                      >
                        {s.label}
                      </div>
                    ))}
                  </div>
                </div>
            </div>

            {areaShifts.map((s) => {
              const start = parseHHMM(s.start_time) ?? startM;
              const end = s.end_time ? parseHHMM(s.end_time) ?? start : start;
              const bks = breaksByShift.get(s.id) ?? [];
              const palette = areaPalette[s.home_area_key] ?? 'bg-slate-100 border-slate-300';

              return (
                <div class="grid" style="grid-template-columns: var(--runsheet-name-col) minmax(0, var(--runsheet-grid-width));">
                  <div class="runsheet-person-cell sticky left-0 z-10 border-t border-slate-100 bg-white px-3 py-2 text-sm">
                    <div class="flex items-center justify-between gap-2">
                      <span class={s.status_key === 'sick' ? 'font-semibold text-rose-700' : 'font-medium text-slate-900'}>
                        {s.name}
                      </span>
                      {s.status_key === 'sick' && <span class="rounded bg-rose-100 px-2 py-0.5 text-xs text-rose-900">Sick</span>}
                    </div>
                    <div class="mt-0.5 text-xs text-slate-600">
                      {s.start_time}–{s.end_time ?? '—'}{formatShiftLength(s.start_time, s.end_time) ? ` · ${formatShiftLength(s.start_time, s.end_time)}` : ''}
                    </div>
                  </div>

                  <div
                    class="relative border-t border-slate-100"
                    style="height: var(--runsheet-row-height); width: var(--runsheet-grid-width);"
                  >
                    {/* grid lines */}
                    {slots.map((sl, i) => (
                      <div
                        class="absolute top-0 h-full border-l border-slate-100"
                        style={`left: calc(${i} * var(--runsheet-slot-width));`}
                      ></div>
                    ))}

                    {/* shift block */}
                    {s.status_key !== 'sick' && (
                      <div
                        class={`runsheet-shift-block absolute top-[6px] h-[30px] rounded-md border ${palette}`}
                        style={`left: calc(${leftSlots(start)} * var(--runsheet-slot-width)); width: calc(${widthSlots(start, end)} * var(--runsheet-slot-width));`}
                        title={`${s.start_time}–${s.end_time}`}
                      ></div>
                    )}

                    {/* break markers */}
                    {s.status_key !== 'sick' &&
                      bks.map((b) => {
                        const bm = parseHHMM(b.start_time);
                        if (bm == null) return null;
                        return (
                          <div
                            class="runsheet-break-marker absolute inset-y-0 flex items-center justify-center text-center text-[10px] font-black leading-[10px] whitespace-pre-line text-slate-900"
                            style={`left: calc(${markerCellCenter(bm)} * var(--runsheet-slot-width) - (var(--runsheet-marker-width) / 2)); width: var(--runsheet-marker-width);`}
                            title={`Break ${b.start_time} (${b.duration_minutes}m)`}
                          >
                            {breakMarker(b.duration_minutes)}
                          </div>
                        );
                      })}
                  </div>
                </div>
              );
            })}
          </div>
        );
      })}
    </div>
  </div>

  <div class="runsheet-legend mt-2 text-xs text-slate-600">
    Break marker legend: 15m = X · 30m = stacked X\nX · 60m = stacked X\nX\nX\nX
  </div>
</section>
)}
