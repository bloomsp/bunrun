---
import { formatDurationMinutes } from '../../lib/time';
import { breakAllowanceMinutes } from '../../lib/breaks';

interface MemberOption {
  id: number;
  name: string;
}

interface ShiftView {
  id: number;
  area_label: string;
  start_time: string;
  end_time: string | null;
}

interface WorkBlockView {
  id: number;
  member_name: string;
  start_time: string;
  end_time: string;
  total_minutes: number;
  shifts: ShiftView[];
}

interface BreakRow {
  id: number;
  shift_id: number;
  start_time: string;
  actual_start_time: string | null;
  duration_minutes: number;
  cover_member_id: number | null;
}

interface Props {
  showBreakPlanning: boolean;
  breakPlanningBlocks: WorkBlockView[];
  breaksByWorkBlock: Map<number, BreakRow[]>;
  plannedBreakMinutesByWorkBlock: Map<number, number>;
  breakPanelUrl: string;
  date: string;
  shiftViewById: Map<number, ShiftView>;
  isBreakValid: (breakId: number, coverMemberId: number | null) => boolean;
  invalidReasonByBreakId: Map<number, string>;
  areaCoveredByBreakId: Map<number, boolean>;
  coverCandidatesByBreakId: Map<number, MemberOption[]>;
}

const {
  showBreakPlanning,
  breakPlanningBlocks,
  breaksByWorkBlock,
  plannedBreakMinutesByWorkBlock,
  breakPanelUrl,
  date,
  shiftViewById,
  isBreakValid,
  invalidReasonByBreakId,
  areaCoveredByBreakId,
  coverCandidatesByBreakId
} = Astro.props;
---

{showBreakPlanning && (
  <>
    {breakPlanningBlocks.length === 0 && (
      <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
        No continuous working blocks are currently available for break planning on this day. If this looks wrong, the roster may need its work blocks recomputed.
      </div>
    )}
    <div class="mt-4 flex flex-wrap gap-2">
      <form method="post" action="/api/breaks/autogen-all">
        <input type="hidden" name="date" value={date} />
        <input type="hidden" name="mode" value="overwrite" />
        <input type="hidden" name="returnTo" value={breakPanelUrl} />
        <button class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800" type="submit">
          Auto-generate ALL (overwrite)
        </button>
      </form>

      <form method="post" action="/api/breaks/autogen-all">
        <input type="hidden" name="date" value={date} />
        <input type="hidden" name="mode" value="missing" />
        <input type="hidden" name="returnTo" value={breakPanelUrl} />
        <button class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm hover:bg-slate-50" type="submit">
          Auto-generate missing only
        </button>
      </form>

      <form method="post" action="/api/breaks/revalidate">
        <input type="hidden" name="date" value={date} />
        <input type="hidden" name="returnTo" value={breakPanelUrl} />
        <button class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm hover:bg-slate-50" type="submit">
          Revalidate
        </button>
      </form>

      <form method="post" action="/api/breaks/autofix">
        <input type="hidden" name="date" value={date} />
        <input type="hidden" name="returnTo" value={breakPanelUrl} />
        <button class="rounded-lg bg-emerald-700 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-800" type="submit">
          Auto-fix covers
        </button>
      </form>
    </div>
    <div class="mt-6 space-y-8">
      {breakPlanningBlocks.map((block) => {
        const rows = breaksByWorkBlock.get(block.id) ?? [];
        const used = plannedBreakMinutesByWorkBlock.get(block.id) ?? 0;
        const allowance = breakAllowanceMinutes(block.total_minutes);
        const shiftSummary = block.shifts.map((shift) => `${shift.area_label} ${shift.start_time}-${shift.end_time ?? '—'}`).join(' · ');

        return (
          <section class="rounded-xl border border-slate-200 bg-slate-50 p-4">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div>
                <div class="font-semibold">{block.member_name}</div>
                <div class="text-sm text-slate-600">
                  {block.start_time}–{block.end_time} · block {formatDurationMinutes(block.total_minutes)} · allowance {allowance}m · planned {used}m
                </div>
                <div class="mt-1 text-xs text-slate-500">{shiftSummary}</div>
              </div>
              <form method="post" action="/api/breaks/autogen">
                <input type="hidden" name="date" value={date} />
                <input type="hidden" name="workBlockId" value={block.id} />
                <input type="hidden" name="returnTo" value={breakPanelUrl} />
                <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm hover:bg-slate-50" type="submit">
                  Auto-generate
                </button>
              </form>
            </div>

            <div class="mt-4 overflow-x-auto">
              <table class="w-full min-w-[1080px] border-separate border-spacing-y-2 text-sm">
                <thead>
                  <tr class="text-left text-slate-600">
                    <th class="px-3">Start</th>
                    <th class="px-3">Area at break</th>
                    <th class="px-3">Duration</th>
                    <th class="px-3">Cover</th>
                    <th class="px-3">Actual taken</th>
                    <th class="px-3"></th>
                  </tr>
                </thead>
                <tbody>
                  {rows.map((b) => {
                    const activeShift = shiftViewById.get(b.shift_id);
                    return (
                      <tr
                        class={
                          !isBreakValid(b.id, b.cover_member_id)
                            ? 'bg-rose-50'
                            : invalidReasonByBreakId.has(b.id)
                              ? 'bg-amber-50'
                              : 'bg-white'
                        }
                      >
                        <td class="px-3 py-3">
                          {b.start_time}
                          {invalidReasonByBreakId.has(b.id) && (
                            <div class="mt-1 text-xs text-amber-900">{invalidReasonByBreakId.get(b.id)}</div>
                          )}
                        </td>
                        <td class="px-3 py-3">{activeShift?.area_label ?? '—'}</td>
                        <td class="px-3 py-3">{b.duration_minutes}m</td>
                        <td class="px-3 py-3">
                          <form method="post" action="/api/breaks/assign-cover" class="flex items-center gap-2">
                            <input type="hidden" name="date" value={date} />
                            <input type="hidden" name="breakId" value={b.id} />
                            <input type="hidden" name="returnTo" value={breakPanelUrl} />
                            <select class="rounded-lg border border-slate-300 bg-white px-2 py-2" name="coverMemberId">
                              <option value="" selected={b.cover_member_id == null}>
                                {areaCoveredByBreakId.get(b.id) ? 'Area covered' : '— missing cover —'}
                              </option>
                              {(coverCandidatesByBreakId.get(b.id) ?? []).map((cs) => (
                                <option value={cs.id} selected={b.cover_member_id === cs.id}>
                                  {cs.name}
                                </option>
                              ))}
                            </select>
                            <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 hover:bg-slate-50" type="submit">
                              Set
                            </button>
                          </form>
                        </td>
                        <td class="px-3 py-3">
                          <div class="flex flex-wrap items-center gap-2">
                            <form method="post" action="/api/breaks/record-taken" class="flex flex-wrap items-center gap-2">
                              <input type="hidden" name="date" value={date} />
                              <input type="hidden" name="breakId" value={b.id} />
                              <input type="hidden" name="returnTo" value={breakPanelUrl} />
                              {(() => {
                                const actual = b.actual_start_time ?? b.start_time;
                                const [hh = '', mm = ''] = actual.split(':');
                                return (
                                  <>
                                    <input class="w-16 rounded-lg border border-slate-300 bg-white px-2 py-2" type="number" name="hh" min="0" max="23" value={hh} required />
                                    <span class="text-slate-600">:</span>
                                    <input class="w-16 rounded-lg border border-slate-300 bg-white px-2 py-2" type="number" name="mm" min="0" max="59" value={mm} required />
                                  </>
                                );
                              })()}
                              <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 hover:bg-slate-50" type="submit">
                                {b.actual_start_time ? 'Update' : 'Record'}
                              </button>
                            </form>
                            {b.actual_start_time && (
                              <form method="post" action="/api/breaks/record-taken">
                                <input type="hidden" name="date" value={date} />
                                <input type="hidden" name="breakId" value={b.id} />
                                <input type="hidden" name="clear" value="1" />
                                <input type="hidden" name="returnTo" value={breakPanelUrl} />
                                <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 hover:bg-slate-50" type="submit">
                                  Clear
                                </button>
                              </form>
                            )}
                          </div>
                          <div class="mt-1 text-xs text-slate-500">
                            {b.actual_start_time ? `Recorded: ${b.actual_start_time}` : 'No actual break time recorded yet'}
                          </div>
                        </td>
                        <td class="px-3 py-3">
                          <form method="post" action="/api/breaks/delete" onsubmit="return confirm('Delete this break?')">
                            <input type="hidden" name="date" value={date} />
                            <input type="hidden" name="breakId" value={b.id} />
                            <input type="hidden" name="returnTo" value={breakPanelUrl} />
                            <button class="rounded-lg border border-slate-300 bg-white px-3 py-2 hover:bg-slate-50" type="submit">
                              Delete
                            </button>
                          </form>
                        </td>
                      </tr>
                    );
                  })}

                  <tr class="bg-white">
                    <td class="px-3 py-3" colspan="6">
                      <form method="post" action="/api/breaks/add" class="flex flex-wrap items-center gap-2">
                        <input type="hidden" name="date" value={date} />
                        <input type="hidden" name="workBlockId" value={block.id} />
                        <input type="hidden" name="returnTo" value={breakPanelUrl} />

                        <div class="mr-2 text-sm font-medium text-slate-700">Add break</div>

                        <input class="w-16 rounded-lg border border-slate-300 bg-white px-2 py-2" type="number" name="hh" min="0" max="23" placeholder="10" required />
                        <span class="text-slate-600">:</span>
                        <input class="w-16 rounded-lg border border-slate-300 bg-white px-2 py-2" type="number" name="mm" min="0" max="59" value="00" required />

                        <select class="rounded-lg border border-slate-300 bg-white px-2 py-2" name="duration">
                          {[15, 30, 45, 60].map((d) => (
                            <option value={d}>{d}m</option>
                          ))}
                        </select>

                        <button class="rounded-lg bg-emerald-700 px-3 py-2 font-medium text-white hover:bg-emerald-800" type="submit">
                          Add
                        </button>
                      </form>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>

            {used > allowance && (
              <div class="mt-3 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-900">
                Planned break time exceeds allowance for this continuous work block.
              </div>
            )}
          </section>
        );
      })}
    </div>
  </>
)}
